          </svg>
        </a>

        <!-- Divider -->
        <div class="w-px h-8 bg-white/10"></div>

        <!-- Language Pills -->
        <div class="flex items-center gap-3">
          {(['ES', 'EN', 'NL', 'FR'] as const).map(code => (
            <button
              data-lang={code}
              data-haptic="light"
              data-ripple
              class="lang-btn ripple-container font-headline text-[14px] font-bold tracking-widest px-4 py-3 rounded border border-white/10 text-white/40 transition-all duration-200 hover:text-[#ffabf1] hover:border-[#ffabf1]/50 hover:bg-[#ffabf1]/5 min-w-[60px] active:scale-90"
            >
              {code}
            </button>
          ))}
        </div>

        <!-- Divider -->
        <div class="w-px h-8 bg-white/10"></div>

        <!-- Facebook -->
        <a href="https://www.facebook.com/paulaangels" target="_blank" rel="noopener noreferrer"
           aria-label="Facebook"
           data-haptic="light"
           data-ripple
           class="ripple-container flex flex-col items-center justify-center p-2 text-white/40 hover:text-[#ffabf1] transition-all duration-300 min-w-[70px] active:scale-95">
          <svg class="w-12 h-12" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>

