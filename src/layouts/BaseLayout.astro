        {bottomNavItems.map((item) => {
          const isActive = currentPath === item.href || currentPath === item.href + '/';
          return (
            <a 
              href={item.href}
              data-haptic="light"
              data-ripple
              class={`ripple-container flex flex-col items-center justify-center p-2 transition-all duration-300 relative group min-w-[80px] ${
                isActive ? 'text-[#ffabf1]' : 'text-white/30 hover:text-white/60'
              }`}
            >
              {/* Active Indicator Top Dot/Line */}
              <div class={`absolute top-0 w-12 h-[2.5px] rounded-full bg-[#ffabf1] transition-all duration-500 transform ${isActive ? 'scale-x-100 opacity-100' : 'scale-x-0 opacity-0 group-hover:scale-x-50'}`}></div>
              
              <span class="material-symbols-outlined text-[40px] transition-transform duration-300 active:scale-125">
                {item.icon}
              </span>
              <span class="font-headline text-[9px] tracking-[0.12em] uppercase mt-1 opacity-60 group-active:opacity-100" data-i18n={item.label}>
                {item.label.split('.')[1]}
              </span>
            </a>
          );
        })}
      </nav>
