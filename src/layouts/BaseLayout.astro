        function applyLang(lang) {
          var dict = T[lang];
          if (!dict) return;
          // Textos inline
          document.querySelectorAll('[data-i18n]').forEach(function(el) {
            var v = dict[el.getAttribute('data-i18n')];
            if (v !== undefined) el.textContent = v;
          });
          // Placeholders de inputs / textareas
          document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el) {
            var v = dict[el.getAttribute('data-i18n-placeholder')];
            if (v !== undefined) el.placeholder = v;
          });
          // lang en <html>
          var m = {ES:'es',EN:'en',NL:'nl',FR:'fr'};
          document.documentElement.setAttribute('lang', m[lang] || 'es');
          // Estado visual de los botones
          document.querySelectorAll('.lang-btn').forEach(function(btn) {
            var on = btn.getAttribute('data-lang') === lang;
            btn.setAttribute('data-current', on ? 'true' : 'false');
            btn.classList.toggle('text-[#ffabf1]', on);
            btn.classList.toggle('border-[#ffabf1]', on);
            btn.classList.toggle('bg-white/5', on);
            btn.classList.toggle('pointer-events-none', on);
            btn.classList.toggle('text-white/40', !on);
            btn.classList.toggle('border-transparent', !on);
          });
        }

        function attachButtons() {
          document.querySelectorAll('.lang-btn').forEach(function(btn) {
            if (btn._i18n) return;
            btn._i18n = true;
            btn.addEventListener('click', function() {
              var l = btn.getAttribute('data-lang');
              if (l && T[l]) {
                localStorage.setItem('site_lang', l);
                applyLang(l);
              }
            });
          });
        }

        // Scroll Reveal Observer
        function initReveal() {
          var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
              }
            });
          }, { threshold: 0.1 });

          document.querySelectorAll('section, .reveal-item').forEach(function(el) {
            if (!el.classList.contains('no-reveal')) {
              el.classList.add('reveal');
              observer.observe(el);
            }
          });
        }

        function initFeedback() {
          // Haptics
          document.addEventListener('click', function(e) {
            var el = e.target.closest('[data-haptic]');
            if (el && navigator.vibrate) {
              var type = el.getAttribute('data-haptic');
              var pattern = type === 'medium' ? [20, 50, 20] : 10;
              navigator.vibrate(pattern);
            }
          });

          // Ripple Effect
          document.addEventListener('click', function(e) {
            var el = e.target.closest('[data-ripple]');
            if (!el) return;
            
            var ripple = document.createElement('span');
            ripple.classList.add('ripple-effect');
            
            var rect = el.getBoundingClientRect();
            var size = Math.max(rect.width, rect.height);
            ripple.style.width = ripple.style.height = size + 'px';
            
            var x = e.clientX - rect.left - size/2;
            var y = e.clientY - rect.top - size/2;
            
            ripple.style.left = x + 'px';
            ripple.style.top = y + 'px';
            
            el.appendChild(ripple);
            setTimeout(function() { ripple.remove(); }, 600);
          });
        }

        function getInitialLang() {
          var saved = localStorage.getItem('site_lang');
          if (saved && T[saved]) return saved;
          
          // Detección automática por configuración de navegador (idioma preferido)
          var navLang = (navigator.language || navigator.userLanguage || 'es').toLowerCase();
          if (navLang.startsWith('nl')) return 'NL';
          if (navLang.startsWith('fr')) return 'FR';
          if (navLang.startsWith('en')) return 'EN';
          return 'ES'; // Default
        }

        function run() {
          var lang = getInitialLang();
          applyLang(lang);
          attachButtons();
          initReveal();
          initFeedback();
        }

        // astro:after-swap = nuevo HTML ya está en DOM (para ClientRouter)
        document.addEventListener('astro:after-swap', run);
        // astro:page-load = primera carga y después de transiciones completas
        document.addEventListener('astro:page-load', run);
        // Seguridad: también al DOMContentLoaded en carga inicial directa
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', run);
        } else {
          run();
        }
      })();
      </script>
