---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CustomCursor from '../components/ui/CustomCursor.astro';
import InteractionEngine from '../components/ui/InteractionEngine.astro';
import TattooAnimatedBg from '../components/ui/TattooAnimatedBg.astro';
import GrainBackground from '../components/ui/GrainBackground.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	lang?: string;
}

const { 
	title = "Tattocaro - Artist Profile", 
	description = "Professional Tattoo Artist Portfolio",
	lang = "es"
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/docs/diseños/logo.png" />
		<link rel="apple-touch-icon" href="/docs/diseños/logo.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body class="selection:bg-studio-purple selection:text-white">
    <GrainBackground />
      <CustomCursor />
      <InteractionEngine />
      <Header />
      <main>
        <slot />
      </main>
      <Footer />

    <script>

      function initScrollProgress() {
        window.addEventListener('scroll', () => {
          const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
          const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
          const scrolled = (winScroll / height) * 100;
          const bar = document.querySelector('.voltage-scroll-bar') as HTMLElement;
          if (bar) bar.style.width = scrolled + "%";
        });
      }

      document.addEventListener('astro:page-load', () => {
        initScrollProgress();
      });
      initScrollProgress(); // Initial run
    </script>
	</body>
</html>
