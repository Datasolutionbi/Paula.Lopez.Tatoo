             target="_blank" rel="noopener noreferrer"
             class="flex items-center justify-center w-16 h-16 rounded-full bg-[#00010d]/80 backdrop-blur-xl border border-[#25d366]/40 text-[#25d366] shadow-[0_0_20px_rgba(37,211,102,0.2)] hover:shadow-[0_0_30px_rgba(37,211,102,0.4)] transition-all duration-300 animate-neon-green group-hover:scale-110 active:scale-95 ripple-container"
             data-haptic="heavy" data-ripple aria-label="WhatsApp">
