---
---

<div class="card p-6 bg-[#0D0D1F]/90 border-cyan-500/20 shadow-xl overflow-hidden relative group/widget">
  <div class="absolute -top-10 -right-10 w-32 h-32 bg-cyan-500/5 blur-3xl rounded-full"></div>
  
  <div class="flex items-center gap-3 mb-6">
    <div class="p-2 bg-cyan-500/10 rounded-lg">
      <svg class="w-5 h-5 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M16 18l6-6-6-6M8 6l-6 6 6 6" />
      </svg>
    </div>
    <div>
      <h4 class="text-sm font-bold text-white uppercase tracking-tight">IA_Decision_Simulator</h4>
      <p class="text-[9px] font-mono text-slate-500">Interactive_Data_Driven_Model</p>
    </div>
  </div>

  <div class="space-y-8">
    <!-- Input Slider -->
    <div class="space-y-4">
      <div class="flex justify-between items-center">
        <label class="text-[10px] font-mono text-blue-400 uppercase">Data_Volume_Input</label>
        <span id="volume-val" class="text-xs font-bold text-white font-mono">500k</span>
      </div>
      <input 
        type="range" 
        id="data-slider" 
        min="10" 
        max="1000" 
        value="500"
        class="w-full h-1 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-cyan-500"
      />
    </div>

    <!-- Output Metrics -->
    <div class="grid grid-cols-2 gap-4">
      <div class="p-3 bg-white/5 border border-white/5 rounded-lg text-center">
        <div class="text-[8px] text-slate-500 uppercase mb-1">Confidence_Level</div>
        <div id="confidence-out" class="text-xl font-black text-cyan-400 font-mono transition-all">92%</div>
      </div>
      <div class="p-3 bg-white/5 border border-white/5 rounded-lg text-center">
        <div class="text-[8px] text-slate-500 uppercase mb-1">ROI_Projection</div>
        <div id="roi-out" class="text-xl font-black text-green-400 font-mono transition-all">3.4x</div>
      </div>
    </div>

    <!-- Live Status -->
    <div class="flex items-center justify-center gap-4 pt-4 border-t border-white/5">
      <div class="flex items-center gap-2">
        <div class="w-1.5 h-1.5 rounded-full bg-cyan-500 animate-ping"></div>
        <span class="text-[8px] font-mono text-slate-400">CALCULATING_INSIGHTS...</span>
      </div>
    </div>
  </div>
</div>

<script>
  function initWidget() {
    const slider = document.getElementById('data-slider') as HTMLInputElement;
    const volumeVal = document.getElementById('volume-val');
    const confidenceOut = document.getElementById('confidence-out');
    const roiOut = document.getElementById('roi-out');

    if (!slider) return;

    slider.addEventListener('input', () => {
      const val = parseInt(slider.value);
      
      // Update volume label
      if (volumeVal) volumeVal.innerText = val >= 1000 ? '1M+' : `${val}k`;

      // Simular cálculo de IA
      const confidence = 85 + (val / 1000) * 10 + (Math.random() * 2);
      const roi = 1.2 + (val / 1000) * 4.5;

      if (confidenceOut) confidenceOut.innerText = `${Math.floor(confidence)}%`;
      if (roiOut) roiOut.innerText = `${roi.toFixed(1)}x`;
      
      // Visual feedback
      if (confidenceOut) {
        confidenceOut.style.textShadow = '0 0 15px rgba(34, 211, 238, 0.5)';
        setTimeout(() => confidenceOut.style.textShadow = 'none', 100);
      }
    });
  }

  // Support for View Transitions
  document.addEventListener('astro:page-load', initWidget);
  // Initial load
  initWidget();
</script>

<style>
  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    height: 12px;
    width: 12px;
    border-radius: 50%;
    background: #22D3EE;
    cursor: pointer;
    box-shadow: 0 0 10px rgba(34, 211, 238, 0.8);
  }
</style>
