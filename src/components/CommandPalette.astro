---
---
<!-- Command Palette UI -->
<div id="command-palette" class="fixed inset-0 z-[10000] bg-[#080813] hidden items-center justify-center p-4">
  <div class="w-full max-w-xl bg-[#0D0D1F] border border-blue-500/40 rounded-xl shadow-[0_0_50px_rgba(0,0,0,0.8)] overflow-hidden">
    <div class="p-4 border-b border-white/5 flex items-center gap-3">
      <span class="text-blue-400 font-mono text-lg">&gt;</span>
      <input 
        type="text" 
        id="command-input" 
        placeholder="Escribe un comando o busca..." 
        class="w-full bg-transparent border-none outline-none text-slate-200 font-mono placeholder:text-slate-600"
        autocomplete="off"
      />
      <kbd class="px-2 py-1 bg-slate-800 text-slate-400 rounded text-[10px] font-mono">ESC</kbd>
    </div>
    <div id="command-results" class="max-h-[300px] overflow-y-auto p-2">
      <!-- Results will be injected here -->
    </div>
    <div class="p-3 bg-blue-500/5 border-t border-white/5 text-[10px] font-mono text-slate-500 flex justify-between">
      <span>↑↓ para navegar</span>
      <span>↵ para ejecutar</span>
    </div>
  </div>
</div>

<script>
  function initCommandPalette() {
    const cp = document.getElementById('command-palette');
    const cpInput = document.getElementById('command-input') as HTMLInputElement;
    const cpResults = document.getElementById('command-results');
    
    const commands = [
      { name: 'Inicio', url: '/', icon: '🏠' },
      { name: 'Proyectos', url: '/#proyectos', icon: '📊' },
      { name: 'Habilidades', url: '/#habilidades', icon: '🛠️' },
      { name: 'Experiencia', url: '/#experiencia', icon: '💼' },
      { name: 'Blog', url: '/blog', icon: '✍️' },
      { name: 'Descargar CV', url: '/cv', icon: '📄' },
      { name: 'Contacto Rápido', url: '/linktree', icon: '📱' },
      { name: 'Run Health Check', action: 'health', icon: '⚡' },
      { name: 'Contacto', url: '/#contacto', icon: '📧' }
    ];

    function handleAction(action: string) {
      if (action === 'health') {
        const overlay = document.getElementById('glitch-overlay');
        overlay?.classList.add('glitch-active');
        setTimeout(() => overlay?.classList.remove('glitch-active'), 1000);
        alert('SYSTEM_HEALTH: 100% | ALL_SYSTEMS_OPERATIONAL');
      }
    }

    function toggleCP(show: boolean) {
      if (cp) {
        cp.classList.toggle('hidden', !show);
        cp.classList.toggle('flex', show);
        if (show) cpInput?.focus();
      }
    }

    function renderResults(filter = '') {
      if (!cpResults) return;
      const filtered = commands.filter(c => c.name.toLowerCase().includes(filter.toLowerCase()));
      cpResults.innerHTML = filtered.map((c) => `
        <a href="${c.url || '#'}" 
           class="flex items-center gap-3 p-3 rounded-lg hover:bg-blue-500/10 text-slate-300 transition-colors group"
           ${c.action ? `data-action="${c.action}"` : ''}>
          <span class="text-xl">${c.icon}</span>
          <span class="flex-1 font-mono text-sm">${c.name}</span>
          <span class="text-[10px] text-slate-600 group-hover:text-blue-400">${c.action ? 'EXECUTE' : 'JUMP TO'} _</span>
        </a>
      `).join('');

      cpResults.querySelectorAll('[data-action]').forEach(el => {
        el.addEventListener('click', (e) => {
          e.preventDefault();
          const action = el.getAttribute('data-action');
          if (action) handleAction(action);
          toggleCP(false);
        });
      });
    }

    window.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        toggleCP(true);
      }
      if (e.key === 'Escape') toggleCP(false);
    });

    cp?.addEventListener('click', (e) => {
      if (e.target === cp) toggleCP(false);
    });

    if (cpInput) {
      cpInput.addEventListener('input', (e) => renderResults((e.target as HTMLInputElement).value));
    }
    renderResults();
  }

  document.addEventListener('astro:page-load', initCommandPalette);
</script>
