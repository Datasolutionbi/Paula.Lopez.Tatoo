---
---
<div id="cursor-ring" class="fixed w-10 h-10 border border-white/20 rounded-none pointer-events-none z-[9999] opacity-0 transition-opacity duration-300 md:block hidden"></div>
<div id="cursor-trail-container" class="fixed inset-0 pointer-events-none z-[9998] md:block hidden"></div>

<script>
  function initCursor() {
    const ring = document.getElementById('cursor-ring');
    const trailContainer = document.getElementById('cursor-trail-container');
    
    if (!ring || !trailContainer) return;

    let lastX = 0;
    let lastY = 0;

    window.addEventListener('mousemove', (e) => {
      ring.style.opacity = '1';
      
      const { clientX: x, clientY: y } = e;
      
      ring.animate({
        transform: `translate(${x - 20}px, ${y - 20}px)`
      }, { duration: 500, fill: "forwards" });

    });

    document.querySelectorAll('a, button, select, textarea').forEach(el => {
      el.addEventListener('mouseenter', () => {
        ring.style.borderColor = '#9D4EDD';
        ring.style.transform += ' scale(1.5)';
      });
      el.addEventListener('mouseleave', () => {
        ring.style.borderColor = 'rgba(255,255,255,0.2)';
        ring.style.transform = ring.style.transform.replace(' scale(1.5)', '');
      });
    });
  }

  document.addEventListener('astro:page-load', initCursor);
  initCursor();
</script>
