---
const { class: className, variant = "minimal" } = Astro.props;

// Variants: 'voltage', 'needle', 'minimal'
---

<div class={`w-full flex items-center justify-center py-6 opacity-80 ${className}`}>
  
  {variant === "voltage" && (
    <svg width="100%" height="40" viewBox="0 0 1200 40" preserveAspectRatio="none" class="opacity-50">
      <path d="M0,20 L400,20 L420,10 L440,30 L460,10 L480,30 L500,20 L700,20 L720,10 L740,30 L760,10 L780,30 L800,20 L1200,20" 
        fill="none" 
        stroke="currentColor" 
        stroke-width="1"
        class="text-studio-purple separator-path" 
      />
    </svg>
  )}

  {variant === "needle" && (
    <div class="relative w-full flex items-center justify-center gap-4">
      <svg width="40%" height="2" viewBox="0 0 400 2" preserveAspectRatio="none">
        <path d="M0,1 L400,1" stroke="currentColor" stroke-width="1" class="text-black/20 separator-path" />
      </svg>
      <div class="w-2 h-2 rounded-full bg-studio-purple animate-pulse"></div>
      <svg width="40%" height="2" viewBox="0 0 400 2" preserveAspectRatio="none">
        <path d="M400,1 L0,1" stroke="currentColor" stroke-width="1" class="text-black/20 separator-path" />
      </svg>
    </div>
  )}

  {variant === "sketch" && (
    <div class="relative w-full flex items-center justify-center opacity-40">
       <svg width="200" height="20" viewBox="0 0 200 20" class="text-studio-purple">
          <path 
            d="M0,10 C30,8 70,12 100,10 C130,8 170,12 200,10" 
            fill="none" 
            stroke="currentColor" 
            stroke-width="1.5"
            stroke-linecap="round"
            class="separator-path"
            style="filter: url(#rough-edge);"
          />
          <defs>
             <filter id="rough-edge">
                <feTurbulence type="fractalNoise" baseFrequency="0.5" numOctaves="2" result="noise" />
                <feDisplacementMap in="SourceGraphic" in2="noise" scale="2" />
             </filter>
          </defs>
       </svg>
    </div>
  )}

  {variant === "minimal" && (
    <div class="relative flex items-center gap-6 group">
      <div class="w-12 h-px bg-black/10 group-hover:w-20 transition-all duration-500"></div>
      <!-- Simple Needle Point -->
      <div class="w-1.5 h-1.5 bg-black/40 rounded-full group-hover:bg-studio-purple transition-colors duration-300"></div>
      <div class="w-12 h-px bg-black/10 group-hover:w-20 transition-all duration-500"></div>
    </div>
  )}

</div>
<script>
  function initDrawingAnimation() {
    const separators = document.querySelectorAll('.separator-path');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const path = entry.target as SVGPathElement;
          const length = path.getTotalLength();
          
          // Reset
          path.style.strokeDasharray = `${length} ${length}`;
          path.style.strokeDashoffset = `${length}`;
          
          // Trigger reflow
          path.getBoundingClientRect();
          
          // Animate
          path.style.transition = 'stroke-dashoffset 2s ease-in-out';
          path.style.strokeDashoffset = '0';
          
          observer.unobserve(path);
        }
      });
    }, { threshold: 0.1 });

    separators.forEach(sep => observer.observe(sep));
  }

  document.addEventListener('astro:page-load', initDrawingAnimation);
  // Also run on initial load
  initDrawingAnimation();
</script>
