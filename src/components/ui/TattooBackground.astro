---
// Traditional Tattoo Flash Icons (Optimized SVGs)
// Expanded collection for better coverage
const icons = [
  // Rose
  { 
    path: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-5-9h10v2H7z",
    style: "top: 10%; left: 10%; animation-duration: 45s; animation-delay: 0s; width: 60px;" 
  },
  // Dagger
  { 
    path: "M12 2L2 22h20L12 2zm0 3.5L18.5 19h-13L12 5.5z M12 10v4",
    style: "top: 25%; left: 85%; animation-duration: 50s; animation-delay: -5s; width: 50px;" 
  },
  // Swallow
  { 
    path: "M20.5 13.5L16 9l-4.5 4.5 4.5 4.5 4.5-4.5z M4 9v9h9V9H4zm7 7H6v-5h5v5z", 
    style: "top: 65%; left: 5%; animation-duration: 55s; animation-delay: -12s; width: 55px;" 
  },
  // Skull
  { 
    path: "M12 2a7 7 0 0 0-7 7c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74a7 7 0 0 0-7-7zm0 11c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4z M10 11h4v2h-4z", 
    style: "top: 55%; right: 15%; animation-duration: 60s; animation-delay: -8s; width: 45px;" 
  },
  // Anchor
  { 
    path: "M12 2c-3.31 0-6 2.69-6 6v7h12V8c0-3.31-2.69-6-6-6zm-4 6c0-2.21 1.79-4 4-4s4 1.79 4 4v5H8V8z M12 18c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z", 
    style: "bottom: 10%; right: 40%; animation-duration: 48s; animation-delay: -15s; width: 50px;" 
  },
  // Snake (Abstract)
  {
    path: "M12 2c-5.52 0-10 4.48-10 10s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z",
    style: "top: 40%; left: 40%; animation-duration: 65s; animation-delay: -20s; width: 70px;"
  },
  // Heart
  {
    path: "M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z",
    style: "bottom: 20%; left: 20%; animation-duration: 42s; animation-delay: -10s; width: 40px;"
  }
];
---

<!-- Paper Texture Background -->
<div class="fixed inset-0 -z-20 bg-[#FAFAFA]"></div>

<!-- Animated Drifting Icons Overlay -->
<div class="fixed inset-0 -z-10 pointer-events-none overflow-hidden select-none">
  {icons.map(icon => (
    <div class="absolute text-black mix-blend-multiply floating-icon opacity-[0.04]" style={icon.style}>
      <svg viewBox="0 0 24 24" fill="currentColor" class="w-full h-full">
        <path d={icon.path} />
      </svg>
    </div>
  ))}
  
  <!-- Subtle Grain Overlay specifically for the background layer -->
  <div class="absolute inset-0 opacity-[0.03] bg-[url('https://www.transparenttextures.com/patterns/stardust.png')]"></div>
</div>

<style>
  .floating-icon {
    animation-name: drift;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    will-change: transform;
    filter: blur(0.5px); /* Ink bleed effect */
  }

  @keyframes drift {
    0% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(20px, 20px) rotate(5deg); }
    50% { transform: translate(0, 40px) rotate(0deg); }
    75% { transform: translate(-20px, 20px) rotate(-5deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }
</style>
