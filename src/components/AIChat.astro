---
const currentPath = Astro.url.pathname;
const isEn = currentPath.includes('/en/');

const content = {
  title: isEn ? "Andres_AI v1.0" : "Andres_IA v1.0",
  welcome: isEn ? "> SYSTEM_INIT... Hi, I am Andres' digital twin. How can I help you today?" : "> SYSTEM_INIT... Hola, soy el gemelo digital de Andres. ¿En qué puedo ayudarte hoy?",
  placeholder: isEn ? "Ask something..." : "Pregunta algo...",
  aria: isEn ? "AI Chat" : "Chat con IA"
};
---
<div class="fixed bottom-24 right-8 z-[100] group">
  <!-- Chat Window -->
  <div id="ai-chat-window" class="absolute bottom-16 right-0 w-80 h-96 bg-[#0D0D1F] border border-blue-500/30 rounded-2xl shadow-[0_20px_50px_rgba(0,0,0,0.5)] flex flex-col hidden opacity-0 translate-y-4 transition-all duration-300">
    <div class="p-4 border-b border-white/5 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
        <span class="text-xs font-mono font-bold text-blue-400 uppercase tracking-widest">{content.title}</span>
      </div>
      <button id="close-chat" class="text-slate-500 hover:text-white transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-width="2"></path></svg>
      </button>
    </div>
    
    <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-4 scrollbar-thin scrollbar-thumb-blue-500/20">
      <div class="bg-blue-500/10 border border-blue-500/20 p-3 rounded-lg text-[10px] font-mono text-slate-300">
        {content.welcome}
      </div>
    </div>

    <div class="p-4 border-t border-white/5">
      <form id="chat-form" class="flex gap-2">
        <input 
          type="text" 
          id="chat-input"
          placeholder={content.placeholder} 
          class="flex-1 bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-[10px] font-mono focus:outline-none focus:border-blue-500/50 transition-colors"
        />
        <button type="submit" class="bg-blue-600 hover:bg-blue-500 text-white p-2 rounded-lg transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"></path></svg>
        </button>
      </form>
    </div>
  </div>

  <!-- Toggle Button -->
  <button 
    id="toggle-chat"
    class="w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center text-white shadow-[0_0_20px_rgba(59,130,246,0.5)] hover:scale-110 active:scale-95 transition-all relative overflow-hidden group"
    aria-label={content.aria}
  >
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></div>
    <svg class="w-6 h-6 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
  </button>
</div>

<script>
  function initChat() {
    const toggle = document.getElementById('toggle-chat');
    const windowEl = document.getElementById('ai-chat-window');
    const close = document.getElementById('close-chat');
    const form = document.getElementById('chat-form') as HTMLFormElement;
    const input = document.getElementById('chat-input') as HTMLInputElement;
    const messages = document.getElementById('chat-messages');
    const isEn = window.location.pathname.includes('/en/');

    function toggleChat() {
      if (windowEl) {
        const isHidden = windowEl.classList.contains('hidden');
        if (isHidden) {
          windowEl.classList.remove('hidden');
          setTimeout(() => {
            windowEl.classList.remove('opacity-0', 'translate-y-4');
          }, 10);
        } else {
          windowEl.classList.add('opacity-0', 'translate-y-4');
          setTimeout(() => {
            windowEl.classList.add('hidden');
          }, 300);
        }
      }
    }

    toggle?.addEventListener('click', toggleChat);
    close?.addEventListener('click', toggleChat);

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text || !messages) return;

      const userMsg = document.createElement('div');
      userMsg.className = 'text-right';
      userMsg.innerHTML = `<span class="inline-block bg-white/5 border border-white/10 p-2 rounded-lg text-[10px] font-mono text-blue-400">> ${text}</span>`;
      messages.appendChild(userMsg);
      input.value = '';
      messages.scrollTop = messages.scrollHeight;

      setTimeout(() => {
        const aiMsg = document.createElement('div');
        aiMsg.className = 'bg-blue-500/10 border border-blue-500/20 p-3 rounded-lg text-[10px] font-mono text-slate-300';
        
        let response = isEn 
          ? "Interesting question. As Andres' digital twin, I can tell you he specializes in BI and Data Science. Want to know about a specific project?"
          : "Interesante pregunta. Como gemelo digital de Andres, puedo decirte que se especializa en BI y Data Science. ¿Quieres saber sobre algún proyecto en particular?";
        
        const lowerText = text.toLowerCase();
        if (lowerText.includes('azure')) {
          response = isEn
            ? "Andres has extensive experience deploying models in Azure ML and managing corporate data lakes."
            : "Andres tiene amplia experiencia desplegando modelos en Azure ML y gestionando data lakes corporativos.";
        } else if (lowerText.includes('python')) {
          response = isEn
            ? "Python is Andres' core language for predictive analysis, ETLs, and process automation."
            : "Python es el lenguaje base de Andres para análisis predictivo, ETLs y automatización de procesos.";
        } else if (lowerText.includes('contacto') || lowerText.includes('contact')) {
          response = isEn
            ? "You can contact Andres via LinkedIn or the contact form at the bottom of this page."
            : "Puedes contactar a Andres vía LinkedIn o por el formulario de contacto al final de esta página.";
        }

        aiMsg.innerHTML = `> ${response}`;
        messages.appendChild(aiMsg);
        messages.scrollTop = messages.scrollHeight;
      }, 1000);
    });
  }

  document.addEventListener('astro:page-load', initChat);
</script>
