---
// Hero.astro - Premium Dark Theme
const { isEn = false } = Astro.props;
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;

const content = {
  es: {
    artist: "Paula",
    surname: "López",
    role: "Tatuadora Profesional",
    description: "Tu elección para una experiencia de tatuaje diferente. Arte tradicional unido a la precisión moderna.",
    bookNow: "RESERVAR AHORA",
    viewPortfolio: "VER PORTFOLIO",
    portfolioHighlights: "DESTACADOS DEL PORTFOLIO",
    scrollDown: "Desplázate hacia abajo"
  },
  en: {
    artist: "Paula",
    surname: "López",
    role: "Tattoo Artist",
    description: "Your choice for a different tattooing experience. Traditional art meets modern precision.",
    bookNow: "BOOK NOW",
    viewPortfolio: "VIEW PORTFOLIO",
    portfolioHighlights: "PORTFOLIO HIGHLIGHTS",
    scrollDown: "Scroll down"
  }
};

const t = isEn ? content.en : content.es;
---

<section class="relative min-h-screen flex items-end overflow-hidden bg-surface-container-lowest">
  <!-- Full-bleed Background Image -->
  <div class="absolute inset-0 z-0 bg-[#00010d]">
    <img 
      src="/Paula.Lopez.Tatoo/paula-artisan.png" 
      alt="" 
      class="w-full h-full object-cover opacity-40 blur-md scale-105"
      loading="eager"
    />
  </div>
  
  <!-- Content gradient overlays for depth (Radial & Linear) -->
  <div class="absolute inset-0 bg-gradient-to-r from-[#00010d] via-transparent to-[#00010d] z-10 pointer-events-none"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-[#00010d] via-transparent to-transparent z-10 pointer-events-none"></div>
  
  <!-- Subtle Grain Texture -->
  <div class="absolute inset-0 opacity-[0.04] pointer-events-none z-20" style="background-image: url('https://www.transparenttextures.com/patterns/stardust.png');"></div>
  
  <!-- Neon Dotted Vertical Line -->
  <div class="absolute left-4 md:left-12 top-0 bottom-0 flex flex-col items-center justify-center gap-2 z-30 opacity-40">
    {Array.from({ length: 40 }).map(() => (
      <div class="w-[2px] h-[2px] bg-primary rounded-full shadow-[0_0_8px_rgba(255,171,241,0.8)]"></div>
    ))}
  </div>
  
  <!-- Content Container -->
  <div class="relative z-30 w-full px-5 md:px-12 lg:px-20 pb-24 md:pb-32 max-w-[1400px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-end">
      
      <!-- Left Column: Main Content -->
      <div class="space-y-8">
        <!-- Artist Name -->
        <h1 class="leading-[0.85] animate-slide-up">
          <span class="block font-display font-light text-5xl md:text-7xl lg:text-[4.5rem] xl:text-[6rem] text-white/90 uppercase tracking-[3px]">
            {t.artist}
          </span>
          <span class="block font-display font-bold text-6xl md:text-8xl lg:text-[7rem] xl:text-[9rem] text-white uppercase tracking-[2px] drop-shadow-[0_0_30px_rgba(255,171,241,0.2)]">
            {t.surname}
          </span>
        </h1>
        
        <!-- Role Subtitle -->
        <p class="text-primary font-headline font-semibold uppercase tracking-[0.4em] text-xs md:text-sm animate-fade-in" style="animation-delay: 0.2s;">
          {t.role}
        </p>
        
        <!-- Description -->
        <p class="text-white/60 font-body text-sm md:text-base max-w-md leading-[1.8] animate-fade-in" style="animation-delay: 0.3s;">
          {t.description}
        </p>
        
        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-4 pt-4 animate-slide-up" style="animation-delay: 0.4s;">
          <a 
            href="/Paula.Lopez.Tatoo/booking" 
            class="inline-block bg-primary-container text-on-primary-container font-headline font-semibold uppercase tracking-[0.25em] text-xs md:text-sm px-10 py-4 hover:shadow-[0_0_20px_rgba(140,39,134,0.6)] hover:-translate-y-1 transition-all duration-300"
          >
            {t.bookNow}
          </a>
          <a 
            href="/Paula.Lopez.Tatoo/portafolio" 
            class="inline-block border border-primary/50 text-primary font-headline font-semibold uppercase tracking-[0.25em] text-xs md:text-sm px-10 py-4 hover:bg-primary/10 hover:border-primary transition-all duration-300"
          >
            {t.viewPortfolio}
          </a>
        </div>
      </div>
      
      <!-- Right Column: Portfolio Mini-Preview -->
      <div class="hidden lg:block animate-fade-in" style="animation-delay: 0.6s;">
        <!-- Label -->
        <p class="text-secondary font-headline font-bold uppercase tracking-[0.3em] text-[9px] mb-6">
          {t.portfolioHighlights}
        </p>
        
        <!-- 3-Image Grid -->
        <div class="grid grid-cols-3 gap-3">
          {[
            { img: "/Paula.Lopez.Tatoo/tattoos/tattoo-1.png" },
            { img: "/Paula.Lopez.Tatoo/tattoos/tattoo-2.png" },
            { img: "/Paula.Lopez.Tatoo/tattoos/tattoo-3.png" }
          ].map((item) => (
            <a href="/Paula.Lopez.Tatoo/portafolio" class="aspect-[4/5] overflow-hidden transition-all duration-700 cursor-pointer group rounded-sm border border-white/5 hover:border-primary/30">
              <img 
                src={item.img} 
                alt="Portfolio highlight" 
                class="w-full h-full object-cover lg:grayscale group-hover:grayscale-0 group-hover:scale-110 transition-transform duration-700"
              />
            </a>
          ))}
        </div>
      </div>
      
    </div>
  </div>
  
  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-30 flex flex-col items-center gap-2 animate-fade-in" style="animation-delay: 1s;">
    <a href="#about" aria-label={t.scrollDown} class="text-primary hover:text-white transition-colors animate-bounce">
      <svg class="w-5 h-5 drop-shadow-[0_0_8px_rgba(255,171,241,0.5)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 5v14M5 12l7 7 7-7"/>
      </svg>
    </a>
  </div>
</section>
