---
// Hero.astro - Modern Editorial Design
const { isEn = false } = Astro.props;

const content = {
  es: {
    artist: "Paula",
    surname: "López",
    role: "Tattoo Artist",
    description: "Tu elección para una experiencia de tatuaje diferente. Arte tradicional unido a la precisión moderna."
  },
  en: {
    artist: "Paula",
    surname: "López",
    role: "Tattoo Artist",
    description: "Your choice for a different tattooing experience. Traditional art meets modern precision."
  }
};

const t = isEn ? content.en : content.es;
---

<section class="min-h-[95vh] flex items-center justify-center pt-32 pb-20 px-6 md:px-12 bg-[var(--bg-page)] overflow-hidden relative">
  <!-- Subtle Parchment Texture Layer -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/natural-paper.png')]"></div>
  
  <div class="max-w-[1400px] w-full grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center relative z-10">
    
    <!-- Left Column: Content -->
    <div class="relative z-10 lg:pr-10">
      <div class="space-y-10">
        <h1 class="flex flex-col leading-[0.85] relative">
          <!-- Decorative accent -->
          <div class="absolute -top-12 -left-6 w-24 h-24 bg-studio-purple/5 blur-3xl rounded-full -z-10"></div>
          
          <span class="font-serif-editorial text-7xl md:text-8xl lg:text-[8rem] xl:text-[9.5rem] text-studio-purple italic mb-2">
            {t.artist}
          </span>
          <span class="font-sans font-black text-6xl md:text-8xl lg:text-[7.5rem] xl:text-[10rem] text-[#222] tracking-tighter uppercase leading-[0.8]">
            {t.surname}
          </span>
        </h1>
        
        <div class="space-y-8 pt-6 border-l border-black/5 pl-8 md:pl-12 relative">
          <!-- Ink Splash decoration -->
          <div class="absolute -right-20 top-0 w-64 h-64 bg-studio-purple/5 ink-stain -z-10 opacity-40"></div>
          
          <p class="text-studio-purple font-black uppercase tracking-[0.4em] text-xs md:text-sm sketch-line inline-block">
            {t.role}
          </p>
          <p class="text-black/50 font-medium text-lg md:text-xl max-w-sm leading-relaxed">
            {t.description}
          </p>
          
          <!-- CTA Action -->
          <div class="pt-4">
             <a href="#booking" class="inline-flex items-center gap-6 group">
                <div class="w-12 h-12 bg-black rounded-full flex items-center justify-center text-white transition-transform group-hover:scale-110">
                   <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-black/60 group-hover:text-black transition-colors">Start Journey</span>
             </a>
          </div>
        </div>

        <!-- Masterpieces Mini-Slider -->
        <div class="pt-12">
           <div class="bg-gray-50/50 backdrop-blur-md rounded-3xl p-8 border border-black/5 relative overflow-hidden group">
              <!-- Glow -->
              <div class="absolute -inset-1 bg-studio-purple/5 blur-xl group-hover:opacity-100 opacity-0 transition-opacity duration-1000"></div>
              
              <div class="relative z-10">
                 <div class="flex items-center justify-between mb-8">
                    <h3 class="text-[9px] font-black uppercase tracking-[0.3em] text-black opacity-40">Portfolio Highlights</h3>
                    <div class="flex gap-3">
                       <button class="w-6 h-6 flex items-center justify-center text-black/20 hover:text-black transition-colors">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                       </button>
                       <button class="w-6 h-6 flex items-center justify-center text-black/20 hover:text-black transition-colors">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                       </button>
                    </div>
                 </div>

                 <div class="grid grid-cols-3 gap-3">
                    {[
                      { img: "/AndresBI/tattoos/tattoo-1.png" },
                      { img: "/AndresBI/tattoos/tattoo-2.png" },
                      { img: "/AndresBI/tattoos/tattoo-3.png" }
                    ].map((item) => (
                      <div class="aspect-[4/5] rounded-xl overflow-hidden grayscale hover:grayscale-0 transition-all duration-700 cursor-pointer">
                        <img src={item.img} class="w-full h-full object-cover" alt="Portfolio Highlights" />
                      </div>
                    ))}
                 </div>
              </div>
           </div>
        </div>
      </div>
    </div>

    <!-- Right Column: Premium Portrait -->
    <div class="relative group mt-12 lg:mt-0">
      <div class="absolute -inset-4 bg-studio-purple/10 blur-3xl rounded-[3rem] opacity-50 group-hover:opacity-100 transition-opacity duration-1000"></div>
      
      <div class="relative rounded-[3rem] overflow-hidden aspect-[4/5] bg-stone-100 shadow-2xl shadow-black/5 transition-transform duration-700 group-hover:scale-[1.02] border border-black/5">
        <img 
          src="/AndresBI/paula_lopez_hero_portrait.png" 
          alt="Paula López Portrait" 
          class="w-full h-full object-cover scale-105 group-hover:scale-100 transition-transform duration-1000"
        />
        
        <!-- Subtle Overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent opacity-60"></div>
        
        <!-- Floating Label: Artisan focus -->
        <div class="absolute bottom-10 left-10 right-10 p-6 bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl flex items-center justify-between">
           <div class="flex flex-col">
              <span class="text-[10px] font-black uppercase tracking-[0.3em] text-white">Consultation Expert</span>
              <span class="text-[9px] font-bold text-white/50 uppercase tracking-widest">Mastering the Ink Since 2012</span>
           </div>
           <div class="w-10 h-10 rounded-full bg-studio-purple flex items-center justify-center text-white shadow-lg shadow-studio-purple/20">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
           </div>
        </div>
      </div>
    </div>

  </div>
</section>
