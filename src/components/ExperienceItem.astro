---
interface Props {
  company: string;
  position: string;
  period: string;
  description: string;
  achievements?: string[];
  tech?: string[];
}

const { company, position, period, description, achievements, tech } = Astro.props;
---

<div class="relative pl-8 pb-12 last:pb-0 group/exp">
  <!-- Timeline Line -->
  <div class="absolute left-[11px] top-0 bottom-0 w-[2px] bg-slate-800 group-last/exp:bg-transparent transition-colors duration-500 group-hover/exp:bg-blue-500/30"></div>
  <!-- Timeline Dot -->
  <div class="absolute left-0 top-2 w-6 h-6 rounded-full border-4 border-[#080813] bg-slate-800 z-10 transition-all duration-500 group-hover/exp:bg-blue-500 group-hover/exp:shadow-[0_0_15px_rgba(59,130,246,0.5)] group-hover/exp:scale-110"></div>

  <div class="card relative overflow-hidden ml-4">
    <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/5 blur-3xl -mr-16 -mt-16 pointer-events-none"></div>
    <div class="flex flex-col md:flex-row md:items-start md:justify-between mb-4">
      <div>
        <h3 class="text-xl font-bold">{position}</h3>
        <p class="text-lg text-blue-400 font-medium">{company}</p>
      </div>
      <span class="text-xs font-bold uppercase tracking-widest text-slate-500 mt-2 md:mt-1.5 bg-slate-800/30 px-3 py-1 rounded-full border border-slate-700/50">{period}</span>
    </div>
    
    <p class="text-slate-400 mb-6 text-sm leading-relaxed">{description}</p>
    
    {achievements && achievements.length > 0 && (
      <ul class="space-y-3 mb-6">
        {achievements.map((achievement) => (
          <li class="text-sm text-slate-300 flex items-start gap-3 group/item">
            <span class="text-blue-500 font-mono font-bold transition-transform group-hover/item:translate-x-1">=&gt;</span>
            <span class="leading-snug">{achievement}</span>
          </li>
        ))}
      </ul>
    )}
    
    {tech && tech.length > 0 && (
      <div class="flex flex-wrap gap-2 pt-5 border-t border-white/5">
        {tech.map((item) => (
          <span class="badge-secondary text-[10px] uppercase tracking-tighter">{item}</span>
        ))}
      </div>
    )}
  </div>
</div>
