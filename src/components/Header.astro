---
import { Image } from 'astro:assets';
import logoFull from '../assets/logo-full.png';
import { SITE } from '../data/site';

const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;

const topNavItems = [
  { label: 'HOME',       href: `${base}/`,           icon: 'home' },
  { label: 'ABOUT ME',   href: `${base}/about`,      icon: 'person' },
  { label: 'MEDIA',      href: `${base}/media`,      icon: 'play_circle' },
  { label: 'PORTAFOLIO', href: `${base}/portafolio`, icon: 'photo_library' },
  { label: 'CONTACTA',   href: `${base}/contacto`,   icon: 'mail' },
  { label: 'FAQ',        href: `${base}/faq`,        icon: 'help_outline' },
  { label: 'SEMINARIOS', href: `${base}/seminarios`, icon: 'school' },
];

const navI18nKeys: Record<string, string> = {
  'HOME': 'nav.home',
  'ABOUT ME': 'nav.about',
  'MEDIA': 'nav.media',
  'PORTAFOLIO': 'nav.portfolio',
  'CONTACTA': 'nav.contact',
  'FAQ': 'nav.faq',
  'SEMINARIOS': 'nav.seminarios',
};
---

<nav class="fixed top-0 w-full z-50 flex items-center gap-2 px-3 lg:px-12 py-4 lg:py-6 bg-[#00010d]/60 backdrop-blur-[30px]">

<!-- Logo — solo desktop dentro del navbar -->
<a href={`${base}/`} class="hidden lg:flex relative flex-shrink-0 items-center w-12 h-12 hover:opacity-80 transition-opacity">
    <Image src={logoFull} alt="Paula Lopez Logo"
         class="absolute top-1/2 -translate-y-1/2 left-0 h-16 w-auto max-w-none object-contain origin-left pointer-events-none" />
</a>

<!-- Desktop nav links -->
<div class="hidden lg:flex items-center gap-6 xl:gap-10 flex-1 justify-center">
    {topNavItems.map((link) => {
        const isActive = currentPath === link.href || currentPath === link.href + '/';
        const i18nKey = navI18nKeys[link.label] || '';
        return (
            <a
                href={link.href}
                class={`group relative font-headline text-[10px] xl:text-xs tracking-[0.3em] uppercase transition-all duration-500 ${
                    isActive ? 'text-[#ffabf1]' : 'text-white/40 hover:text-white'
                }`}
            >
                <span data-i18n={i18nKey}>{link.label}</span>
                {/* Underline animated for active/hover */}
                <span class={`absolute -bottom-2 left-0 h-[1px] bg-gradient-to-r from-[#ffabf1] to-transparent transition-all duration-500 ${isActive ? 'w-full opacity-100' : 'w-0 opacity-0 group-hover:w-full group-hover:opacity-100'}`}></span>
            </a>
        );
    })}
    <!-- Desktop Language Selector -->
    <div class="flex items-center gap-2 border-l border-white/5 pl-6 ml-4">
        {(['ES', 'EN', 'NL', 'FR'] as const).map(code => (
            <button 
                data-lang={code} 
                class="lang-btn font-headline text-[9px] tracking-widest px-2.5 py-1.5 transition-all duration-300 rounded border border-transparent hover:bg-white/5"
            >
                {code}
            </button>
        ))}
    </div>
</div>

        {/* Mobile Navigation - Layout Simple & Asertivo */}
        <div class="lg:hidden flex items-center justify-between flex-1 pl-2">
            {/* Logo Mobile - Large & Clean (User Request) */}
            <a href={`${base}/`} class="flex-shrink-0 active:scale-95 transition-transform duration-300 group">
                <Image src={logoFull} alt="Logo" class="h-16 w-auto object-contain" />
            </a>

            {/* Mobile Language Selector - Asigned by User Image */}
            <div class="flex items-center gap-1 px-1">
                {(['ES', 'EN', 'NL', 'FR'] as const).map(code => (
                    <button 
                        data-lang={code} 
                        data-haptic="light"
                        data-ripple
                        class="lang-btn flex-none ripple-container font-headline text-[9px] tracking-widest px-2.5 py-1.5 transition-all duration-300 rounded-sm border border-white/5 bg-white/2 hover:border-[#ffabf1]/30 hover:text-[#ffabf1] data-[current=true]:text-[#ffabf1] data-[current=true]:border-[#ffabf1]/40 data-[current=true]:bg-[#ffabf1]/5 shadow-sm"
                    >
                        {code}
                    </button>
                ))}
            </div>

            {/* Actions: Cita + Hamburger */}
            <div class="flex items-center gap-3">
                <a 
                    href={`${base}/contacto`} 
                    data-haptic="medium"
                    data-ripple
                    class="ripple-container btn-primary flex items-center justify-center p-3 rounded-xl border border-[#ffabf1]/40 bg-[#ffabf1]/10 text-[#ffabf1] active:scale-90 transition-all duration-200 animate-pulse-neon"
                    aria-label="Consulta"
                >
                    <span class="material-symbols-outlined text-[24px]">mail</span>
                    <span class="hidden md:inline ml-2" data-i18n="nav.cta">Consulta</span>
                </a>
                
                {/* WhatsApp Mobile - User Request to add to Header */}
                <a 
                    href={`https://wa.me/${SITE.phone.replace(/\D/g, '')}`}
                    target="_blank" rel="noopener noreferrer"
                    data-haptic="heavy"
                    data-ripple
                    class="ripple-container flex items-center justify-center p-3 rounded-xl border border-[#25d366]/40 bg-[#25d366]/10 text-[#25d366] active:scale-90 transition-all duration-200 animate-pulse-green"
                    aria-label="WhatsApp"
                >
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                    </svg>
                </a>

                <button 
                    id="mobile-menu-btn" 
                    data-haptic="medium"
                    data-ripple
                    class="ripple-container lg:hidden flex items-center justify-center p-3 rounded-xl bg-white/5 border border-white/10 text-[#ffabf1] active:scale-90 transition-all duration-300" 
                    aria-label="Toggle Menu"
                >
                    <span class="material-symbols-outlined text-[32px]">menu</span>
                </button>
            </div>
        </div>

</nav>

<style>
    @keyframes pulse-neon {
        0%, 100% {
            opacity: 1;
            box-shadow: 0 0 5px rgba(255, 171, 241, 0.2);
            border-color: rgba(255, 171, 241, 0.4);
        }
        50% {
            opacity: 0.8;
            box-shadow: 0 0 15px rgba(255, 171, 241, 0.5);
            border-color: rgba(255, 171, 241, 0.8);
            transform: scale(1.05);
        }
    }
    @keyframes pulse-green {
        0%, 100% {
            opacity: 1;
            box-shadow: 0 0 5px rgba(37, 211, 102, 0.2);
            border-color: rgba(37, 211, 102, 0.4);
        }
        50% {
            opacity: 0.8;
            box-shadow: 0 0 15px rgba(37, 211, 102, 0.5);
            border-color: rgba(37, 211, 102, 0.8);
            transform: scale(1.05);
        }
    }
    .animate-pulse-neon {
        animation: pulse-neon 2s infinite ease-in-out;
    }
    .animate-pulse-green {
        animation: pulse-green 2s infinite ease-in-out;
    }
</style>


<div id="mobile-menu" class="fixed inset-0 bg-[#00010d]/95 backdrop-blur-[30px] z-[60] flex flex-col pt-32 px-12 opacity-0 pointer-events-none transition-opacity duration-500 overflow-y-auto">
    <button id="close-menu-btn" class="absolute top-8 right-12 text-[#ffabf1] hover:rotate-90 active:scale-125 transition-all duration-300" aria-label="Close Menu">
        <span class="material-symbols-outlined text-[48px]">close</span>
    </button>

    <!-- Social top bar inside menu -->
    <div class="flex items-center justify-center gap-8 mb-12">
        <a href="https://www.instagram.com/paulaangels/" target="_blank" rel="noopener noreferrer"
           aria-label="Instagram"
           class="group flex items-center justify-center w-14 h-14 rounded-full border border-white/10 text-white/40 hover:text-[#ffabf1] hover:border-[#ffabf1]/50 hover:bg-[#ffabf1]/5 hover:drop-shadow-[0_0_15px_rgba(255,171,241,0.3)] transition-all duration-300 active:scale-125">
            <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
        </a>
        <a href="https://www.facebook.com/paulaangels" target="_blank" rel="noopener noreferrer"
           aria-label="Facebook"
           class="group flex items-center justify-center w-14 h-14 rounded-full border border-white/10 text-white/40 hover:text-[#ffabf1] hover:border-[#ffabf1]/50 hover:bg-[#ffabf1]/5 hover:drop-shadow-[0_0_15px_rgba(255,171,241,0.3)] transition-all duration-300 active:scale-125">
            <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
        </a>
    </div>

    <div class="w-full grid grid-cols-2 gap-3 pb-4">
        {topNavItems.filter(link => link.label !== 'HOME').map((link) => {
            const isActive = currentPath === link.href || currentPath === link.href + '/';
            const i18nKey = navI18nKeys[link.label] || '';
            return (
                <a
                    href={link.href}
                    class={`flex flex-col items-center justify-center gap-2 py-5 px-3 rounded-xl border transition-all duration-300 ${
                        isActive
                            ? 'border-[#ffabf1]/50 bg-[#ffabf1]/8 text-[#ffabf1] drop-shadow-[0_0_12px_rgba(255,171,241,0.2)]'
                            : 'border-white/8 bg-white/3 text-white/50 hover:text-[#ffabf1] hover:border-[#ffabf1]/30 hover:bg-white/5'
                    }`}
                >
                    <span class="material-symbols-outlined text-2xl">{link.icon}</span>
                    <span class={`font-headline text-[9px] tracking-[0.25em] uppercase`} data-i18n={i18nKey}>{link.label}</span>
                </a>
            );
        })}
    </div>
</div>

<script>
    function setupMobileMenu() {
        const btn = document.getElementById('mobile-menu-btn');
        const closeBtn = document.getElementById('close-menu-btn');
        const menu = document.getElementById('mobile-menu');
        
        if(!btn || !closeBtn || !menu) return;

        const openMenu = () => {
            menu.classList.remove('opacity-0', 'pointer-events-none');
            document.body.style.overflow = 'hidden';
        };

        const closeMenu = () => {
            menu.classList.add('opacity-0', 'pointer-events-none');
            document.body.style.overflow = '';
        };

        btn.addEventListener('click', openMenu);
        closeBtn.addEventListener('click', closeMenu);
        
        const links = menu.querySelectorAll('a');
        links.forEach(link => {
            link.addEventListener('click', closeMenu);
        });
    }

    document.addEventListener('astro:page-load', () => {
        setupMobileMenu();
    });
    setupMobileMenu();
</script>
