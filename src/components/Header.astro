---
import { Image } from 'astro:assets';
import logoFull from '../assets/logo-full.png';

const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;

const topNavItems = [
  { label: 'HOME',       href: `${base}/`,           icon: 'home' },
  { label: 'ABOUT ME',   href: `${base}/about`,      icon: 'person' },
  { label: 'MEDIA',      href: `${base}/media`,      icon: 'play_circle' },
  { label: 'PORTAFOLIO', href: `${base}/portafolio`, icon: 'photo_library' },
  { label: 'CONTACTA',   href: `${base}/contacto`,   icon: 'mail' },
  { label: 'FAQ',        href: `${base}/faq`,        icon: 'help_outline' },
  { label: 'SEMINARIOS', href: `${base}/seminarios`, icon: 'school' },
];

const navI18nKeys: Record<string, string> = {
  'HOME': 'nav.home',
  'ABOUT ME': 'nav.about',
  'MEDIA': 'nav.media',
  'PORTAFOLIO': 'nav.portfolio',
  'CONTACTA': 'nav.contact',
  'FAQ': 'nav.faq',
  'SEMINARIOS': 'nav.seminarios',
};
---

<nav class="fixed top-0 w-full z-50 flex items-center gap-2 px-3 lg:px-12 py-4 lg:py-6 bg-[#00010d]/60 backdrop-blur-[30px]">

<!-- Logo — solo desktop dentro del navbar -->
<a href={`${base}/`} class="hidden lg:flex relative flex-shrink-0 items-center w-12 h-12 hover:opacity-80 transition-opacity">
    <Image src={logoFull} alt="Paula Lopez Logo"
         class="absolute top-1/2 -translate-y-1/2 left-0 h-16 w-auto max-w-none object-contain origin-left pointer-events-none" />
</a>

<!-- Desktop nav links -->
<div class="hidden lg:flex items-center gap-6 xl:gap-10 flex-1 justify-center">
    {topNavItems.map((link) => {
        const isActive = currentPath === link.href || currentPath === link.href + '/';
        const i18nKey = navI18nKeys[link.label] || '';
        return (
            <a
                href={link.href}
                class={`group relative font-headline text-[10px] xl:text-xs tracking-[0.3em] uppercase transition-all duration-500 ${
                    isActive ? 'text-[#ffabf1]' : 'text-white/40 hover:text-white'
                }`}
            >
                <span data-i18n={i18nKey}>{link.label}</span>
                {/* Underline animated for active/hover */}
                <span class={`absolute -bottom-2 left-0 h-[1px] bg-gradient-to-r from-[#ffabf1] to-transparent transition-all duration-500 ${isActive ? 'w-full opacity-100' : 'w-0 opacity-0 group-hover:w-full group-hover:opacity-100'}`}></span>
            </a>
        );
    })}
    <!-- Desktop Language Selector -->
    <div class="flex items-center gap-2 border-l border-white/5 pl-6 ml-4">
        {(['ES', 'EN', 'NL', 'FR'] as const).map(code => (
            <button 
                data-lang={code} 
                class="lang-btn font-headline text-[9px] tracking-widest px-2.5 py-1.5 transition-all duration-300 rounded border border-transparent hover:bg-white/5"
            >
                {code}
            </button>
        ))}
    </div>
</div>

{(() => {
    const mobileItems = topNavItems.filter(link => link.label !== 'HOME');
    // For 7 items, we split as 3 | LOGO | 4
    const midPoint = 3;
    const firstHalf = mobileItems.slice(0, midPoint);
    const secondHalf = mobileItems.slice(midPoint);

    return (
        <div class="lg:hidden flex-1 overflow-x-auto no-scrollbar">
            <div class="flex items-center justify-center gap-1 min-w-full px-2">
                {/* First Half (3 items) */}
                {firstHalf.map((link) => {
                    const isActive = currentPath === link.href || currentPath === link.href + '/';
                    const i18nKey = navI18nKeys[link.label] || '';
                    return (
                        <a
                            href={link.href}
                            data-haptic="light"
                            data-ripple
                            class={`ripple-container flex flex-col items-center justify-center gap-2.5 min-w-[90px] flex-none py-2 transition-all duration-300 ${
                                isActive ? 'text-[#ffabf1]' : 'text-white/30'
                            }`}
                        >
                            <span class="material-symbols-outlined text-[48px] transition-transform duration-300 active:scale-125">{link.icon}</span>
                            <span class="font-headline text-[13px] tracking-[0.05em] uppercase whitespace-nowrap" data-i18n={i18nKey}>{link.label}</span>
                        </a>
                    );
                })}

                {/* Centered Logo - Premium touch */}
                <a href={`${base}/`} class="flex-shrink-0 mx-6 px-1 active:scale-95 transition-transform duration-300 group">
                    <Image src={logoFull} alt="Logo" class="h-24 w-auto object-contain drop-shadow-[0_0_20px_rgba(255,171,241,0.25)] group-hover:drop-shadow-[0_0_35px_rgba(255,171,241,0.5)] transition-all duration-500" />
                </a>

                {/* Second Half (4 items) */}
                {secondHalf.map((link) => {
                    const isActive = currentPath === link.href || currentPath === link.href + '/';
                    const i18nKey = navI18nKeys[link.label] || '';
                    const isContact = link.label === 'CONTACTA';
                    return (
                        <a
                            href={link.href}
                            data-haptic="light"
                            data-ripple
                            class={`ripple-container flex flex-col items-center justify-center gap-2.5 min-w-[90px] flex-none py-2 transition-all duration-300 ${
                                isActive ? 'text-[#ffabf1]' : 'text-white/30'
                            }`}
                        >
                            <span class={`material-symbols-outlined transition-transform duration-300 active:scale-125 ${isContact ? 'text-[56px] text-[#ffabf1]' : 'text-[48px]'}`}>{link.icon}</span>
                            <span class="font-headline text-[13px] tracking-[0.05em] uppercase whitespace-nowrap" data-i18n={i18nKey}>{link.label}</span>
                        </a>
                    );
                })}
            </div>
        </div>
    );
})()}

<!-- Right side: CTA + hamburger -->
<div class="flex-shrink-0 flex items-center gap-2">
    <a href={`${base}/contacto`} class="btn-primary hidden md:block text-[10px]">
        <span data-i18n="nav.cta">Consulta</span>
    </a>
    <button id="mobile-menu-btn" class="lg:hidden text-[#ffabf1] active:scale-125 transition-transform duration-300" aria-label="Toggle Menu">
        <span class="material-symbols-outlined text-[40px]">menu</span>
    </button>
</div>

</nav>


<div id="mobile-menu" class="fixed inset-0 bg-[#00010d]/95 backdrop-blur-[30px] z-[60] flex flex-col pt-32 px-12 opacity-0 pointer-events-none transition-opacity duration-500 overflow-y-auto">
    <button id="close-menu-btn" class="absolute top-8 right-12 text-[#ffabf1] hover:rotate-90 active:scale-125 transition-all duration-300" aria-label="Close Menu">
        <span class="material-symbols-outlined text-[48px]">close</span>
    </button>

    <!-- Social top bar inside menu -->
    <div class="flex items-center justify-center gap-8 mb-12">
        <a href="https://www.instagram.com/paulaangels/" target="_blank" rel="noopener noreferrer"
           aria-label="Instagram"
           class="group flex items-center justify-center w-14 h-14 rounded-full border border-white/10 text-white/40 hover:text-[#ffabf1] hover:border-[#ffabf1]/50 hover:bg-[#ffabf1]/5 hover:drop-shadow-[0_0_15px_rgba(255,171,241,0.3)] transition-all duration-300 active:scale-125">
            <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
        </a>
        <a href="https://www.facebook.com/paulaangels" target="_blank" rel="noopener noreferrer"
           aria-label="Facebook"
           class="group flex items-center justify-center w-14 h-14 rounded-full border border-white/10 text-white/40 hover:text-[#ffabf1] hover:border-[#ffabf1]/50 hover:bg-[#ffabf1]/5 hover:drop-shadow-[0_0_15px_rgba(255,171,241,0.3)] transition-all duration-300 active:scale-125">
            <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
        </a>
    </div>

    <div class="w-full grid grid-cols-2 gap-3 pb-4">
        {topNavItems.filter(link => link.label !== 'HOME').map((link) => {
            const isActive = currentPath === link.href || currentPath === link.href + '/';
            const i18nKey = navI18nKeys[link.label] || '';
            return (
                <a
                    href={link.href}
                    class={`flex flex-col items-center justify-center gap-2 py-5 px-3 rounded-xl border transition-all duration-300 ${
                        isActive
                            ? 'border-[#ffabf1]/50 bg-[#ffabf1]/8 text-[#ffabf1] drop-shadow-[0_0_12px_rgba(255,171,241,0.2)]'
                            : 'border-white/8 bg-white/3 text-white/50 hover:text-[#ffabf1] hover:border-[#ffabf1]/30 hover:bg-white/5'
                    }`}
                >
                    <span class="material-symbols-outlined text-2xl">{link.icon}</span>
                    <span class={`font-headline text-[9px] tracking-[0.25em] uppercase`} data-i18n={i18nKey}>{link.label}</span>
                </a>
            );
        })}
    </div>
</div>

<script>
    function setupMobileMenu() {
        const btn = document.getElementById('mobile-menu-btn');
        const closeBtn = document.getElementById('close-menu-btn');
        const menu = document.getElementById('mobile-menu');
        
        if(!btn || !closeBtn || !menu) return;

        const openMenu = () => {
            menu.classList.remove('opacity-0', 'pointer-events-none');
            document.body.style.overflow = 'hidden';
        };

        const closeMenu = () => {
            menu.classList.add('opacity-0', 'pointer-events-none');
            document.body.style.overflow = '';
        };

        btn.addEventListener('click', openMenu);
        closeBtn.addEventListener('click', closeMenu);
        
        const links = menu.querySelectorAll('a');
        links.forEach(link => {
            link.addEventListener('click', closeMenu);
        });
    }

    document.addEventListener('astro:page-load', () => {
        setupMobileMenu();
    });
    setupMobileMenu();
</script>
