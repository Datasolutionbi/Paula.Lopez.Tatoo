---
// Header.astro - Modern Editorial Design inspired by reference
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
const isEn = currentPath.includes('/en/') || currentPath.endsWith('/en');
---

<header id="main-header" class="sticky top-0 z-[150] transition-all duration-500 bg-white border-b border-black/5">
  <div class="px-6 md:px-12 max-w-[1400px] mx-auto py-3 flex items-center justify-between">
    
    <!-- Left: Logo & Menu -->
    <div class="flex items-center gap-4 md:gap-8">
      <button class="flex flex-col gap-1.5 group focus:outline-none">
        <span class="w-6 h-0.5 bg-black transition-all group-hover:w-4"></span>
        <span class="w-6 h-0.5 bg-black"></span>
        <span class="w-6 h-0.5 bg-black transition-all group-hover:w-5"></span>
      </button>
      
      <a href={isEn ? `${base}/en/` : (base || '/')} class="flex items-center gap-3 group">
        <div class="w-8 h-8 bg-black flex items-center justify-center transition-transform group-hover:scale-105">
          <div class="w-4 h-4 border-2 border-white"></div>
        </div>
        <div class="flex flex-col leading-none">
          <span class="font-bold text-sm tracking-tighter uppercase text-black">Studio</span>
          <span class="text-[9px] uppercase opacity-50 font-bold tracking-[0.1em] -mt-0.5">Tattoocaro</span>
        </div>
      </a>
    </div>

    <!-- Center: Navigation Links -->
    <nav class="hidden lg:flex items-center gap-10">
      {[
        { label: 'Home', href: isEn ? `${base}/en/` : (base || '/') },
        { label: 'Gallery', href: '#gallery' },
        { label: 'About', href: '#about' },
        { label: 'FAQ', href: '#faq' }
      ].map((link) => (
        <a 
          href={link.href} 
          class="text-xs font-bold uppercase tracking-[0.1em] text-black/60 hover:text-black hover:opacity-100 transition-all relative group"
        >
          {link.label}
          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-black transition-all group-hover:w-full"></span>
        </a>
      ))}
    </nav>

    <!-- Right: Action Button -->
    <div class="flex items-center gap-4">
      <a 
        href="/booking" 
        class="bg-[var(--purple-primary)] text-white px-5 md:px-8 py-2.5 rounded-full text-[11px] md:text-xs font-black uppercase tracking-widest shadow-lg shadow-purple-900/20 hover:bg-[var(--purple-dark)] hover:scale-105 active:scale-95 transition-all duration-300"
      >
        Book Session
      </a>
    </div>
  </div>
</header>

<style>
  #main-header.scrolled {
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
  
  #main-header.scrolled > div > div {
    background-color: rgba(255, 255, 255, 0.95);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
  }
</style>

<script>
  function handleScroll() {
    const header = document.getElementById('main-header');
    if (window.scrollY > 20) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }
  
  document.addEventListener('astro:page-load', () => {
    window.addEventListener('scroll', handleScroll);
    handleScroll();
  });
</script>
