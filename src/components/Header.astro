---
import { SITE } from '../data/site';

const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
const isEn = currentPath.includes('/en/') || currentPath.endsWith('/en');
const isHome = currentPath === base || currentPath === base + '/' || currentPath === base + '/index.html' || isEn;

const sectionLinks = [
  { name: isEn ? 'About Me' : 'Sobre Mí', href: '#sobre-mi' },
  { name: isEn ? 'Projects' : 'Proyectos', href: '#proyectos' },
  { name: isEn ? 'Tech Stack' : 'Stack Técnico', href: '#habilidades' },
  { name: isEn ? 'Experience' : 'Experiencia', href: '#experiencia' },
  { name: isEn ? 'Education' : 'Educación', href: '#educacion' },
  { name: isEn ? 'Contact' : 'Contacto', href: '#contacto' },
];
---

<header id="main-header" class="sticky top-0 z-[150] bg-[#080813] border-b border-white/5">
  <nav class="container-custom py-4">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href={isEn ? `${base}/en/` : (base || '/')} class="flex items-center gap-3 group">
        <div class="relative w-10 h-10 flex items-center justify-center">
          <!-- Glassmorphism Ring -->
          <div class="absolute inset-0 bg-blue-500/5 rounded-xl border border-blue-500/20 group-hover:border-blue-400/50 group-hover:bg-blue-500/10 transition-all duration-500 rotate-45 group-hover:rotate-0 shadow-[0_0_15px_rgba(59,130,246,0.1)]"></div>
          
          <svg class="w-6 h-6 text-blue-400 relative z-10 transition-all duration-500 group-hover:scale-110" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 16V11" class="animate-logo-bar-1" />
            <path d="M12 16V7" class="animate-logo-bar-2" />
            <path d="M17 16V13" class="animate-logo-bar-3" />
            <circle cx="12" cy="12" r="9" class="stroke-white/5" stroke-dasharray="2 4" />
            <circle r="1" fill="currentColor" class="text-cyan-400">
              <animateMotion dur="4s" repeatCount="indefinite" path="M12,3 A9,9 0 1,1 11.9,3" />
            </circle>
            <circle cx="12" cy="12" r="1.5" fill="currentColor" class="text-cyan-400 animate-pulse" />
          </svg>
        </div>
        <div class="flex flex-col items-stretch ml-4">
          <span class="text-xs font-extrabold text-white tracking-widest leading-none">
            <span>ANDRES</span><span class="text-yellow-400">BI</span><span class="text-blue-500 animate-pulse">_</span>
          </span>
          <div class="flex items-center justify-between mt-1 px-0.5 opacity-40">
            <span class="text-[6px] font-bold text-blue-400 uppercase tracking-tighter">UX_D_IA</span>
          </div>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        <!-- Inicio with Dropdown -->
        <div class="relative group/nav-item">
          <div 
            class={`text-sm font-bold uppercase tracking-widest transition-colors flex items-center gap-1 cursor-default ${isHome ? 'text-blue-400' : 'text-slate-300'}`}
          >
            {isEn ? 'Home' : 'Inicio'}
            <svg class="w-3 h-3 transition-transform group-hover/nav-item:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="3"></path></svg>
          </div>
          
          <!-- Dropdown Menu -->
          <div class="absolute top-full left-0 pt-4 opacity-0 translate-y-2 pointer-events-none group-hover/nav-item:opacity-100 group-hover/nav-item:translate-y-0 group-hover/nav-item:pointer-events-auto transition-all duration-300 z-[100]">
            <div class="w-48 nexus-dropdown">
              {sectionLinks.map((link) => (
                <a 
                  href={isHome ? link.href : (isEn ? `${base}/en/${link.href}` : `${base}/${link.href}`)}
                  class="flex items-center px-4 py-2.5 text-[10px] font-mono font-bold text-slate-400 hover:text-blue-400 hover:bg-blue-500/5 rounded-lg transition-all"
                  data-section-link
                >
                  <span class="text-blue-500/40 mr-2">></span> {link.name}
                </a>
              ))}
            </div>
          </div>
        </div>

        <a href={`${base}/blog`} class="text-sm font-bold uppercase tracking-widest text-slate-300 hover:text-blue-400">Blog</a>
        <a href={`${base}/docs`} class="text-sm font-bold uppercase tracking-widest text-slate-300 hover:text-blue-400">Docs</a>
        
        <a href={SITE.github} target="_blank" class="text-slate-300 hover:text-blue-400"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg></a>

        <!-- Availability -->
        <div class="flex items-center gap-2 px-3 py-1 rounded-full bg-green-500/5 border border-green-500/10">
          <span class="relative flex h-1.5 w-1.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-green-500"></span>
          </span>
          <span class="text-[8px] font-mono text-green-500/80 uppercase tracking-tighter">Live</span>
        </div>

        <!-- Language Selector -->
        <div class="flex gap-2 text-[10px] font-mono border-l border-white/10 pl-4 ml-2">
          <a href={base || '/'} class={`hover:text-blue-400 transition-colors ${!isEn ? 'text-blue-400 font-bold underline' : 'text-slate-500'}`}>ES</a>
          <span class="text-slate-700">|</span>
          <a href={`${base}/en/`} class={`hover:text-blue-400 transition-colors ${isEn ? 'text-blue-400 font-bold underline' : 'text-slate-500'}`}>EN</a>
        </div>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-button" class="md:hidden text-slate-300 p-2"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16" stroke-width="2"></path></svg></button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="fixed inset-0 z-[200] bg-[#0D0D1F] hidden flex-col items-center justify-center p-8 overflow-y-auto">
      <button id="close-menu" class="absolute top-8 right-8 text-slate-400 p-2"><svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-width="1.5"></path></svg></button>
      <div class="flex flex-col gap-6 w-full max-w-xs">
        <a href={isEn ? `${base}/en/` : (base || '/')} class="mobile-nav-link text-white font-bold">01. {isEn ? 'Home' : 'Inicio'}</a>
        <div class="pl-8 flex flex-col gap-4 border-l border-white/5">
          {sectionLinks.map((link, i) => (
            <a href={isHome ? link.href : (isEn ? `${base}/en/${link.href}` : `${base}/${link.href}`)} class="text-sm font-mono text-slate-100 hover:text-blue-400" data-section-link>
              <span class="text-blue-500/30 mr-2">1.{i+1}</span> {link.name}
            </a>
          ))}
        </div>
        <a href={`${base}/blog`} class="mobile-nav-link text-white">02. Blog</a>
        <a href={`${base}/docs`} class="mobile-nav-link text-white">03. Docs</a>
        <div class="flex gap-4 text-xs font-mono border-t border-white/5 pt-6 mt-2">
          <a href={base || '/'} class={!isEn ? 'text-blue-400 font-bold' : 'text-slate-500'}>ES_SPANISH</a>
          <a href={`${base}/en/`} class={isEn ? 'text-blue-400 font-bold' : 'text-slate-500'}>EN_ENGLISH</a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  function initHeader() {
    const header = document.getElementById('main-header');
    const menuButton = document.getElementById('mobile-menu-button');
    const closeButton = document.getElementById('close-menu');
    const mobileMenu = document.getElementById('mobile-menu');
    const allLinks = document.querySelectorAll('nav a');
    const sectionLinks = document.querySelectorAll('[data-section-link]');

    function toggleMenu(show: boolean) {
      if (mobileMenu && header) {
        if (show) {
          mobileMenu.classList.remove('hidden');
          mobileMenu.classList.add('flex');
          header.classList.add('z-[250]');
          document.body.style.overflow = 'hidden';
        } else {
          mobileMenu.classList.add('hidden');
          mobileMenu.classList.remove('flex');
          header.classList.remove('z-[250]');
          document.body.style.overflow = 'auto';
        }
      }
    }

    menuButton?.addEventListener('click', () => toggleMenu(true));
    closeButton?.addEventListener('click', () => toggleMenu(false));
    
    allLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        if (href && href.includes('#')) {
          const targetId = href.split('#').pop();
          const targetElement = targetId ? document.getElementById(targetId) : null;
          if (targetElement) {
            e.preventDefault();
            targetElement.scrollIntoView({ behavior: 'smooth', block: 'start' });
            window.history.pushState(null, '', `#${targetId}`);
          }
        }
        toggleMenu(false);
      });
    });

    const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
    const isHome = window.location.pathname === base || window.location.pathname === base + '/' || window.location.pathname.includes('/en/');
    
    if (isHome) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            sectionLinks.forEach(link => {
              const href = link.getAttribute('href');
              if (href && (href.endsWith(`#${id}`) || href === `#${id}`)) {
                link.classList.add('text-blue-400', 'bg-blue-500/10');
                link.classList.remove('text-slate-100', 'text-slate-400');
              } else {
                link.classList.remove('text-blue-400', 'bg-blue-500/10');
                if (link.classList.contains('text-sm')) {
                   link.classList.add('text-slate-100');
                } else {
                   link.classList.add('text-slate-400');
                }
              }
            });
          }
        });
      }, { rootMargin: '-10% 0px -85% 0px' });

      ['sobre-mi', 'proyectos', 'habilidades', 'experiencia', 'educacion', 'contacto'].forEach(id => {
        const el = document.getElementById(id);
        if (el) observer.observe(el);
      });
    }
  }
  document.addEventListener('astro:page-load', initHeader);
</script>
