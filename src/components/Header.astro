---
import { SITE } from '../data/site';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-[#080813]/40 backdrop-blur-lg border-b border-white/5">
  <nav class="container-custom py-4">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="relative w-10 h-10 flex items-center justify-center">
          <!-- Glassmorphism Ring (UX/Interface) -->
          <div class="absolute inset-0 bg-blue-500/5 rounded-xl border border-blue-500/20 group-hover:border-blue-400/50 group-hover:bg-blue-500/10 transition-all duration-500 rotate-45 group-hover:rotate-0 shadow-[0_0_15px_rgba(59,130,246,0.1)]"></div>
          
          <!-- Core Data/AI Symbol -->
          <svg class="w-6 h-6 text-blue-400 relative z-10 transition-all duration-500 group-hover:scale-110" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <!-- Data Bars with Gradient Feel -->
            <path d="M7 16V11" class="group-hover:stroke-blue-300 transition-all" />
            <path d="M12 16V7" class="group-hover:stroke-cyan-400 transition-all" />
            <path d="M17 16V13" class="group-hover:stroke-blue-300 transition-all" />
            
            <!-- AI Orbital/Neural Circle -->
            <circle cx="12" cy="12" r="9" class="stroke-white/10 group-hover:stroke-blue-400/30 transition-all" stroke-dasharray="2 4" />
            
            <!-- Central Intelligence Node -->
            <circle cx="12" cy="12" r="1.5" fill="currentColor" class="text-cyan-400 animate-pulse shadow-[0_0_8px_rgba(34,211,238,0.8)]" />
          </svg>
        </div>
        <div class="flex flex-col items-stretch">
          <span class="text-xs font-extrabold text-white tracking-widest leading-none transition-all whitespace-nowrap">
            <span class="group-hover:text-blue-400 transition-colors">ANDRES</span><span class="text-yellow-400 group-hover:text-amber-300 transition-colors">BI</span><span class="text-blue-500">_</span>
          </span>
          <div class="flex items-center justify-between mt-1 px-0.5">
            <span class="text-[6px] font-bold text-blue-400/40 uppercase tracking-tight">UX</span>
            <span class="w-0.5 h-0.5 bg-white/20 rounded-full"></span>
            <span class="text-[6px] font-bold text-blue-400/40 uppercase tracking-tight">DATA</span>
            <span class="w-0.5 h-0.5 bg-white/20 rounded-full"></span>
            <span class="text-[6px] font-bold text-blue-400/40 uppercase tracking-tight">IA</span>
          </div>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        <a 
          href="/" 
          class={`text-sm font-medium transition-colors relative group/link ${currentPath === '/' ? 'text-blue-400' : 'text-slate-300 hover:text-blue-400'}`}
        >
          {currentPath === '/' && <span class="absolute -left-3 animate-pulse text-blue-500 font-bold">&gt;</span>}
          Inicio
          <span class={`absolute -bottom-1 left-0 h-px bg-blue-500 transition-all duration-300 ${currentPath === '/' ? 'w-full' : 'w-0 group-hover/link:w-full'}`}></span>
        </a>
        <a 
          href="/blog" 
          class={`text-sm font-medium transition-colors relative group/link ${currentPath.startsWith('/blog') ? 'text-blue-400' : 'text-slate-300 hover:text-blue-400'}`}
        >
          {currentPath.startsWith('/blog') && <span class="absolute -left-3 animate-pulse text-blue-500 font-bold">&gt;</span>}
          Blog
          <span class={`absolute -bottom-1 left-0 h-px bg-blue-500 transition-all duration-300 ${currentPath.startsWith('/blog') ? 'w-full' : 'w-0 group-hover/link:w-full'}`}></span>
        </a>
        <a 
          href="/docs" 
          class={`text-sm font-medium transition-colors relative group/link ${currentPath.startsWith('/docs') ? 'text-blue-400' : 'text-slate-300 hover:text-blue-400'}`}
        >
          {currentPath.startsWith('/docs') && <span class="absolute -left-3 animate-pulse text-blue-500 font-bold">&gt;</span>}
          Docs
          <span class={`absolute -bottom-1 left-0 h-px bg-blue-500 transition-all duration-300 ${currentPath.startsWith('/docs') ? 'w-full' : 'w-0 group-hover/link:w-full'}`}></span>
        </a>
        <a 
          href={SITE.github} 
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-300 hover:text-blue-400 transition-colors"
          aria-label="GitHub"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button 
        id="mobile-menu-button" 
        class="md:hidden text-slate-300 hover:text-blue-400"
        aria-label="Abrir menú"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation Overlay -->
    <div id="mobile-menu" class="fixed inset-0 z-[100] bg-[#080813]/95 backdrop-blur-2xl hidden flex-col items-center justify-center p-8 transition-all duration-500">
      <button id="close-menu" class="absolute top-8 right-8 text-slate-400 hover:text-white transition-colors p-2">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="flex flex-col gap-8 w-full max-w-xs">
        <div class="font-mono text-[10px] text-blue-500/40 uppercase tracking-[0.5em] mb-4 border-b border-white/5 pb-4 text-center">
          System_Navigation
        </div>
        
        <a href="/" class={`mobile-nav-link ${currentPath === '/' ? 'active' : ''}`}>
          <span>01.</span> Inicio
        </a>
        <a href="/blog" class={`mobile-nav-link ${currentPath.startsWith('/blog') ? 'active' : ''}`}>
          <span>02.</span> Blog
        </a>
        <a href="/docs" class={`mobile-nav-link ${currentPath.startsWith('/docs') ? 'active' : ''}`}>
          <span>03.</span> Docs
        </a>
        <a href={SITE.github} target="_blank" rel="noopener noreferrer" class="mobile-nav-link text-blue-400/60">
          <span>04.</span> GitHub_
        </a>

        <div class="mt-12 pt-8 border-t border-white/5 text-center">
          <p class="text-[8px] font-mono text-slate-600 uppercase tracking-widest">Session_AndresBI_Active</p>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  function initHeader() {
    const menuButton = document.getElementById('mobile-menu-button');
    const closeButton = document.getElementById('close-menu');
    const mobileMenu = document.getElementById('mobile-menu');
    const navLinks = document.querySelectorAll('.mobile-nav-link');

    function toggleMenu(show: boolean) {
      if (mobileMenu) {
        if (show) {
          mobileMenu.classList.remove('hidden');
          mobileMenu.classList.add('flex');
          document.body.style.overflow = 'hidden';
        } else {
          mobileMenu.classList.add('hidden');
          mobileMenu.classList.remove('flex');
          document.body.style.overflow = 'auto';
        }
      }
    }

    menuButton?.addEventListener('click', () => toggleMenu(true));
    closeButton?.addEventListener('click', () => toggleMenu(false));
    
    navLinks.forEach(link => {
      link.addEventListener('click', () => toggleMenu(false));
    });
  }

  // Support for View Transitions
  document.addEventListener('astro:page-load', initHeader);
</script>
