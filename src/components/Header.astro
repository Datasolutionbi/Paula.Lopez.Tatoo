---
import { SITE } from '../data/site';

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

const sectionLinks = [
  { name: 'Sobre Mí', href: '#sobre-mi' },
  { name: 'Proyectos', href: '#proyectos' },
  { name: 'Stack Técnico', href: '#habilidades' },
  { name: 'Experiencia', href: '#experiencia' },
  { name: 'Educación', href: '#educacion' },
  { name: 'Contacto', href: '#contacto' },
];
---

<header class="sticky top-0 z-50 bg-[#080813]/40 backdrop-blur-lg border-b border-white/5">
  <nav class="container-custom py-4">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="relative w-10 h-10 flex items-center justify-center">
          <!-- Glassmorphism Ring -->
          <div class="absolute inset-0 bg-blue-500/5 rounded-xl border border-blue-500/20 group-hover:border-blue-400/50 group-hover:bg-blue-500/10 transition-all duration-500 rotate-45 group-hover:rotate-0 shadow-[0_0_15px_rgba(59,130,246,0.1)]"></div>
          
          <svg class="w-6 h-6 text-blue-400 relative z-10 transition-all duration-500 group-hover:scale-110" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 16V11" class="group-hover:stroke-blue-300 transition-all" />
            <path d="M12 16V7" class="group-hover:stroke-cyan-400 transition-all" />
            <path d="M17 16V13" class="group-hover:stroke-blue-300 transition-all" />
            <circle cx="12" cy="12" r="9" class="stroke-white/10 group-hover:stroke-blue-400/30 transition-all" stroke-dasharray="2 4" />
            <circle cx="12" cy="12" r="1.5" fill="currentColor" class="text-cyan-400 animate-pulse shadow-[0_0_8px_rgba(34,211,238,0.8)]" />
          </svg>
        </div>
        <div class="flex flex-col items-stretch">
          <span class="text-xs font-extrabold text-white tracking-widest leading-none">
            <span class="group-hover:text-blue-400 transition-colors">ANDRES</span><span class="text-yellow-400">BI</span><span class="text-blue-500">_</span>
          </span>
          <div class="flex items-center justify-between mt-1 px-0.5 opacity-40">
            <span class="text-[6px] font-bold text-blue-400 uppercase">UX</span>
            <span class="text-[6px] font-bold text-blue-400 uppercase">DATA</span>
            <span class="text-[6px] font-bold text-blue-400 uppercase">IA</span>
          </div>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        <!-- Inicio with Dropdown -->
        <div class="relative group/nav-item">
          <div 
            class={`text-sm font-bold uppercase tracking-widest transition-colors flex items-center gap-1 cursor-default ${isHome ? 'text-blue-400' : 'text-slate-300 group-hover/nav-item:text-blue-400'}`}
          >
            Inicio
            <svg class="w-3 h-3 transition-transform group-hover/nav-item:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="3"></path></svg>
          </div>
          
          <!-- Dropdown Menu -->
          <div class="absolute top-full left-0 pt-4 opacity-0 translate-y-2 pointer-events-none group-hover/nav-item:opacity-100 group-hover/nav-item:translate-y-0 group-hover/nav-item:pointer-events-auto transition-all duration-300 z-[100]">
            <div class="w-48 glass-panel p-2 border-blue-500/20 shadow-[0_10px_40px_rgba(0,0,0,0.5)]">
              {sectionLinks.map((link) => (
                <a 
                  href={isHome ? link.href : `/${link.href}`}
                  class="flex items-center px-4 py-2.5 text-[10px] font-mono font-bold text-slate-400 hover:text-blue-400 hover:bg-blue-500/5 rounded-lg transition-all"
                  data-section-link
                >
                  <span class="text-blue-500/40 mr-2">></span>
                  {link.name}
                </a>
              ))}
            </div>
          </div>
        </div>

        <a 
          href="/blog" 
          class={`text-sm font-bold uppercase tracking-widest transition-colors relative group/link ${currentPath.startsWith('/blog') ? 'text-blue-400' : 'text-slate-300 hover:text-blue-400'}`}
        >
          Blog
          <span class={`absolute -bottom-1 left-0 h-px bg-blue-500 transition-all duration-300 ${currentPath.startsWith('/blog') ? 'w-full' : 'w-0 group-hover/link:w-full'}`}></span>
        </a>
        
        <a 
          href="/docs" 
          class={`text-sm font-bold uppercase tracking-widest transition-colors relative group/link ${currentPath.startsWith('/docs') ? 'text-blue-400' : 'text-slate-300 hover:text-blue-400'}`}
        >
          Docs
          <span class={`absolute -bottom-1 left-0 h-px bg-blue-500 transition-all duration-300 ${currentPath.startsWith('/docs') ? 'w-full' : 'w-0 group-hover/link:w-full'}`}></span>
        </a>

        <!-- Availability -->
        <div class="flex items-center gap-2 px-3 py-1 rounded-full bg-green-500/5 border border-green-500/10">
          <span class="relative flex h-1.5 w-1.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-green-500"></span>
          </span>
          <span class="text-[8px] font-mono text-green-500/80 uppercase tracking-tighter">Live</span>
        </div>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-button" class="md:hidden text-slate-300 p-2"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16" stroke-width="2"></path></svg></button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="fixed inset-0 z-[100] bg-[#080813]/95 backdrop-blur-2xl hidden flex-col items-center justify-center p-8">
      <button id="close-menu" class="absolute top-8 right-8 text-slate-400 p-2"><svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-width="1.5"></path></svg></button>
      <div class="flex flex-col gap-6 w-full max-w-xs">
        <a href="/" class="mobile-nav-link active"><span>01.</span> Inicio</a>
        <div class="pl-8 flex flex-col gap-4 border-l border-white/5">
          {sectionLinks.map((link, i) => (
            <a 
              href={isHome ? link.href : `/${link.href}`} 
              class="text-sm font-mono text-slate-500 hover:text-blue-400"
              data-section-link
            >
              <span class="text-blue-500/30 mr-2">1.{i+1}</span> {link.name}
            </a>
          ))}
        </div>
        <a href="/blog" class="mobile-nav-link"><span>02.</span> Blog</a>
        <a href="/docs" class="mobile-nav-link"><span>03.</span> Docs</a>
      </div>
    </div>
  </nav>
</header>

<script>
  function initHeader() {
    const menuButton = document.getElementById('mobile-menu-button');
    const closeButton = document.getElementById('close-menu');
    const mobileMenu = document.getElementById('mobile-menu');
    const allLinks = document.querySelectorAll('nav a');
    const sectionLinks = document.querySelectorAll('[data-section-link]');

    // Smooth Scroll Interceptor
    sectionLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        if (href && href.includes('#')) {
          const targetId = href.split('#')[1];
          const targetElement = document.getElementById(targetId);

          if (targetElement) {
            e.preventDefault();
            // Close mobile menu if open
            if (mobileMenu) {
              mobileMenu.classList.add('hidden');
              mobileMenu.classList.remove('flex');
              document.body.style.overflow = 'auto';
            }
            
            // Smooth scroll to target
            targetElement.scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });

            // Update URL without reload
            window.history.pushState(null, '', `#${targetId}`);
          }
        }
      });
    });

    function toggleMenu(show: boolean) {
      if (mobileMenu) {
        mobileMenu.classList.toggle('hidden', !show);
        mobileMenu.classList.toggle('flex', show);
        document.body.style.overflow = show ? 'hidden' : 'auto';
      }
    }

    menuButton?.addEventListener('click', () => toggleMenu(true));
    closeButton?.addEventListener('click', () => toggleMenu(false));
    allLinks.forEach(link => link.addEventListener('click', () => toggleMenu(false)));

    // Active Section Observer for Dropdown & Home Navigation
    if (window.location.pathname === '/') {
      const observerOptions = {
        root: null,
        rootMargin: '-10% 0px -85% 0px', // Detect near top
        threshold: 0
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            sectionLinks.forEach(link => {
              const href = link.getAttribute('href');
              // Check for both absolute and relative anchor
              if (href === `#${id}` || href === `/#${id}`) {
                link.classList.add('text-blue-400', 'bg-blue-500/10');
                link.classList.remove('text-slate-400');
              } else {
                link.classList.remove('text-blue-400', 'bg-blue-500/10');
                link.classList.add('text-slate-400');
              }
            });
          }
        });
      }, observerOptions);

      // Explicitly monitor these IDs
      const sectionIds = ['sobre-mi', 'proyectos', 'habilidades', 'experiencia', 'educacion', 'contacto'];
      sectionIds.forEach(id => {
        const el = document.getElementById(id);
        if (el) observer.observe(el);
      });
    }
  }

  document.addEventListener('astro:page-load', initHeader);
</script>
