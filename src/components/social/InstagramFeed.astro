---
// In a real implementation, you would fetch from Instagram API
// For now, using placeholder images
const instagramPosts = [
  { id: '1', image: 'https://images.unsplash.com/photo-1590204753862-392842497b68?q=80&w=400', link: 'https://instagram.com/p/example1' },
  { id: '2', image: 'https://images.unsplash.com/photo-1560707303-4e980ce876ad?q=80&w=400', link: 'https://instagram.com/p/example2' },
  { id: '3', image: 'https://images.unsplash.com/photo-1598371380356-6169994bc91d?q=80&w=400', link: 'https://instagram.com/p/example3' },
  { id: '4', image: 'https://images.unsplash.com/photo-1611501275019-9b5cda994e8d?q=80&w=400', link: 'https://instagram.com/p/example4' },
  { id: '5', image: 'https://images.unsplash.com/photo-1565058379802-bbe93b2f703f?q=80&w=400', link: 'https://instagram.com/p/example5' },
  { id: '6', image: 'https://images.unsplash.com/photo-1590204751439-2a5e8f3f2a6e?q=80&w=400', link: 'https://instagram.com/p/example6' }
];
---

<section class="py-20 bg-studio-dark/50">
  <div class="container-custom">
    <div class="text-center mb-12 reveal-effect">
      <h2 class="font-display text-4xl md:text-5xl mb-4">LATEST WORK</h2>
      <a 
        href="https://instagram.com/tattocaro" 
        target="_blank"
        class="inline-flex items-center gap-2 font-modern text-xs uppercase tracking-widest text-studio-purple hover:text-white transition-colors group"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        Follow @tattocaro
        <span class="group-hover:translate-x-1 transition-transform">→</span>
      </a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {instagramPosts.map((post, index) => (
        <a 
          href={post.link}
          target="_blank"
          class="instagram-post relative aspect-square overflow-hidden rounded-none group reveal-effect"
          style={`transition-delay: ${index * 50}ms`}
        >
          <img 
            src={post.image} 
            alt="Instagram post"
            class="w-full h-full object-cover  group-hover:-0 group-hover:scale-110 transition-all duration-700"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center pb-6">
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
