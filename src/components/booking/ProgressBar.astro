---
interface Props {
  currentStep: number;
  totalSteps: number;
}

const { currentStep, totalSteps } = Astro.props;
const progress = (currentStep / totalSteps) * 100;
---

<div class="wizard-progress mb-12">
  <div class="flex justify-between mb-4">
    {Array.from({ length: totalSteps }, (_, i) => i + 1).map(step => (
      <div class="flex flex-col items-center flex-1">
        <div 
          class={`w-10 h-10 rounded-none flex items-center justify-center font-bold text-sm transition-all duration-300 ${
            step < currentStep 
              ? 'bg-studio-purple text-black' 
              : step === currentStep 
              ? 'bg-studio-purple text-black ring-4 ring-studio-purple/30' 
              : 'bg-white/10 text-white/40'
          }`}
        >
          {step < currentStep ? '✓' : step}
        </div>
        <span class="text-[8px] uppercase tracking-widest mt-2 opacity-50">
          {step === 1 ? 'Type' : step === 2 ? 'Placement' : 'Details'}
        </span>
      </div>
    ))}
  </div>
  
  <div class="h-1 bg-white/10 rounded-none overflow-hidden">
    <div 
      class="h-full bg-gradient-to-r from-studio-purple to-pink-500 transition-all duration-500 ease-out"
      style={`width: ${progress}%`}
    ></div>
  </div>
</div>
