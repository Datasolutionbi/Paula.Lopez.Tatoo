---
interface ProjectType {
  id: 'coverup' | 'original' | 'flash';
  title: string;
  description: string;
  priceRange: string;
  icon: string;
}

const projectTypes: ProjectType[] = [
  {
    id: 'coverup',
    title: 'COVER-UP',
    description: 'Transform an old tattoo into something new',
    priceRange: '$400 - $1,500',
    icon: '🔄'
  },
  {
    id: 'original',
    title: 'ORIGINAL DESIGN',
    description: 'Custom artwork created just for you',
    priceRange: '$300 - $1,200',
    icon: '✨'
  },
  {
    id: 'flash',
    title: 'FLASH DESIGN',
    description: 'Choose from pre-made designs',
    priceRange: '$150 - $600',
    icon: '⚡'
  }
];
---

<div class="space-y-8">
  <div class="text-center reveal-effect">
    <h2 class="font-display text-4xl md:text-5xl mb-4">WHAT ARE YOU LOOKING FOR?</h2>
    <p class="font-modern text-xs uppercase tracking-widest opacity-50">Select your project type</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {projectTypes.map(type => (
      <button
        type="button"
        class="project-type-card glass-card p-8 text-left transition-all duration-300 hover:scale-105 hover:border-gold group cursor-pointer reveal-effect"
        data-project-type={type.id}
      >
        <div class="text-5xl mb-4 group-hover:scale-110 transition-transform">{type.icon}</div>
        <h3 class="font-display text-2xl mb-3 group-hover:text-gold transition-colors">{type.title}</h3>
        <p class="font-modern text-xs opacity-60 mb-4 leading-relaxed">{type.description}</p>
        <div class="flex items-center justify-between">
          <span class="text-gold font-bold text-sm">{type.priceRange}</span>
          <div class="w-6 h-6 rounded-none border-2 border-white/20 group-hover:border-gold group-hover:bg-gold transition-all flex items-center justify-center">
            <div class="w-3 h-3 rounded-none bg-gold opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>
        </div>
      </button>
    ))}
  </div>

  <div class="text-center mt-8">
    <label class="inline-flex items-center gap-3 cursor-pointer group">
      <input type="checkbox" id="hasReference" class="w-5 h-5 rounded-none border-white/20 bg-[#1a1a1a] text-gold focus:ring-gold focus:ring-offset-0">
      <span class="font-modern text-xs uppercase tracking-widest opacity-60 group-hover:opacity-100 transition-opacity">
        I have reference images
      </span>
    </label>
  </div>
</div>

<script>
  function initStep1() {
    const cards = document.querySelectorAll('.project-type-card');
    let selectedType: string | null = null;

    cards.forEach(card => {
      card.addEventListener('click', () => {
        // Remove selection from all cards
        cards.forEach(c => {
          c.classList.remove('border-gold', 'bg-gold/10');
        });

        // Add selection to clicked card
        card.classList.add('border-gold', 'bg-gold/10');
        selectedType = (card as HTMLElement).dataset.projectType || null;

        // Store in session
        if (selectedType) {
          sessionStorage.setItem('booking_projectType', selectedType);
          
          const hasRef = (document.getElementById('hasReference') as HTMLInputElement)?.checked || false;
          sessionStorage.setItem('booking_hasReference', hasRef.toString());

          // Enable next button
          const nextBtn = document.getElementById('wizard-next');
          if (nextBtn) {
            nextBtn.removeAttribute('disabled');
            nextBtn.classList.remove('opacity-50', 'cursor-not-allowed');
          }
        }
      });
    });

    // Handle reference checkbox
    const refCheckbox = document.getElementById('hasReference');
    refCheckbox?.addEventListener('change', (e) => {
      const checked = (e.target as HTMLInputElement).checked;
      sessionStorage.setItem('booking_hasReference', checked.toString());
    });

    // Restore selection if exists
    const savedType = sessionStorage.getItem('booking_projectType');
    if (savedType) {
      const savedCard = document.querySelector(`[data-project-type="${savedType}"]`);
      if (savedCard) {
        savedCard.classList.add('border-gold', 'bg-gold/10');
        const nextBtn = document.getElementById('wizard-next');
        if (nextBtn) {
          nextBtn.removeAttribute('disabled');
          nextBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
      }
    }

    const savedRef = sessionStorage.getItem('booking_hasReference');
    if (savedRef === 'true') {
      const checkbox = document.getElementById('hasReference') as HTMLInputElement;
      if (checkbox) checkbox.checked = true;
    }
  }

  document.addEventListener('astro:page-load', initStep1);
  initStep1();
</script>

<style>
  .project-type-card {
    border: 2px solid transparent;
  }

  .project-type-card:hover {
    border-color: rgba(168, 126, 47, 0.5);
  }
</style>
