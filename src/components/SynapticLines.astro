---
---
<div class="absolute inset-0 pointer-events-none z-0 overflow-hidden hidden lg:block" id="synaptic-container">
  <svg class="w-full h-full opacity-20" id="synaptic-svg">
    <defs>
      <linearGradient id="synaptic-grad" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#3B82F6" stop-opacity="0" />
        <stop offset="50%" stop-color="#22D3EE" stop-opacity="1" />
        <stop offset="100%" stop-color="#3B82F6" stop-opacity="0" />
      </linearGradient>
    </defs>
    <g id="synaptic-paths"></g>
  </svg>
</div>

<script>
  function drawSynapses() {
    const svg = document.getElementById('synaptic-svg');
    const container = document.getElementById('synaptic-paths');
    const radar = document.querySelector('.skill-radar-center'); // We'll add this class to SkillRadar
    const cards = document.querySelectorAll('.skill-category-card'); // And this to cards

    if (!svg || !container || !radar || cards.length === 0) return;

    const svgRect = svg.getBoundingClientRect();
    const radarRect = radar.getBoundingClientRect();
    const centerX = radarRect.left - svgRect.left + radarRect.width / 2;
    const centerY = radarRect.top - svgRect.top + radarRect.height / 2;

    container.innerHTML = '';

    cards.forEach((card, i) => {
      const cardRect = card.getBoundingClientRect();
      const cardX = cardRect.left - svgRect.left + (i % 2 === 0 ? cardRect.width : 0);
      const cardY = cardRect.top - svgRect.top + cardRect.height / 2;

      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      const cp1X = centerX + (cardX - centerX) * 0.5;
      const cp2X = centerX + (cardX - centerX) * 0.5;
      
      const d = `M ${centerX} ${centerY} C ${cp1X} ${centerY}, ${cp2X} ${cardY}, ${cardX} ${cardY}`;
      
      path.setAttribute('d', d);
      path.setAttribute('stroke', 'url(#synaptic-grad)');
      path.setAttribute('stroke-width', '1');
      path.setAttribute('fill', 'none');
      path.classList.add('synapse-path');
      
      // Animation element
      const animate = document.createElementNS('http://www.w3.org/2000/svg', 'animate');
      animate.setAttribute('attributeName', 'stroke-dashoffset');
      animate.setAttribute('from', '1000');
      animate.setAttribute('to', '0');
      animate.setAttribute('dur', `${3 + Math.random() * 2}s`);
      animate.setAttribute('repeatCount', 'indefinite');
      
      path.setAttribute('stroke-dasharray', '10, 50');
      path.appendChild(animate);
      container.appendChild(path);
    });
  }

  // Initial draw and resize
  window.addEventListener('resize', drawSynapses);
  document.addEventListener('astro:page-load', () => {
    setTimeout(drawSynapses, 500); // Wait for layout
  });
</script>

<style is:global>
  .synapse-path {
    filter: drop-shadow(0 0 2px #22D3EE);
    opacity: 0.5;
    transition: opacity 0.3s ease, stroke-width 0.3s ease;
  }
  .skill-category-card:hover ~ #synaptic-container .synapse-path {
    opacity: 0.8;
    stroke-width: 1.5;
  }
</style>
