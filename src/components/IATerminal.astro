---
---

<div class="max-w-2xl mx-auto mt-12 font-mono text-xs overflow-hidden rounded-lg border border-blue-500/20 bg-[#0D0D1F]/80 backdrop-blur-md shadow-2xl reveal-blur">
  <!-- Terminal Header -->
  <div class="flex items-center justify-between px-4 py-2 bg-blue-500/10 border-b border-white/5">
    <div class="flex gap-1.5">
      <div class="w-2 h-2 rounded-full bg-red-500/50"></div>
      <div class="w-2 h-2 rounded-full bg-yellow-500/50"></div>
      <div class="w-2 h-2 rounded-full bg-green-500/50"></div>
    </div>
    <span class="text-[10px] text-blue-400/60 uppercase tracking-widest">ANDRESBI_IA_V1.0</span>
  </div>

  <!-- Terminal Content -->
  <div id="terminal-body" class="p-4 h-64 overflow-y-auto space-y-2 scrollbar-thin scrollbar-thumb-blue-500/20">
    <div class="text-blue-400/80">&gt; INITIALIZING_IA_AGENT... DONE</div>
    <div class="text-blue-400/80">&gt; TYPE 'help' TO SEE AVAILABLE COMMANDS</div>
  </div>

  <!-- Terminal Input -->
  <div class="flex items-center gap-2 px-4 py-3 bg-white/5 border-t border-white/5">
    <span class="text-cyan-400 font-bold">$</span>
    <input 
      type="text" 
      id="terminal-input" 
      class="flex-1 bg-transparent border-none outline-none text-slate-200"
      placeholder="Escribe un comando..."
      autocomplete="off"
    />
  </div>
</div>

<script>
  const input = document.getElementById('terminal-input') as HTMLInputElement;
  const body = document.getElementById('terminal-body');

  const responses: Record<string, string> = {
    'help': 'Available commands: bio, skills, projects, contact, clear',
    'bio': 'AndresBI: Specialist in BI, UX, and IA. Focused on turning complex data into actionable insights.',
    'skills': 'Stack: Power BI, SQL, Python, Azure ML, UI/UX Design, React, Astro.',
    'projects': 'Check the "Proyectos" section below for case studies on BI and ML.',
    'contact': 'Email: andresbi@example.com | LinkedIn: /in/andresbi',
  };

  function addLine(text: string, colorClass = 'text-slate-300') {
    if (!body) return;
    const line = document.createElement('div');
    line.className = colorClass;
    line.innerHTML = `&gt; ${text}`;
    body.appendChild(line);
    body.scrollTop = body.scrollHeight;
  }

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const cmd = input.value.trim().toLowerCase();
      input.value = '';
      
      if (cmd === '') return;
      
      addLine(cmd, 'text-cyan-400 font-bold');
      
      if (cmd === 'clear') {
        if (body) body.innerHTML = '';
        addLine('TERMINAL_CLEARED', 'text-blue-400/60');
      } else if (responses[cmd]) {
        setTimeout(() => addLine(responses[cmd]), 100);
      } else {
        setTimeout(() => addLine(`Command not found: ${cmd}. Type 'help' for options.`, 'text-red-400/60'), 100);
      }
    }
  });
</script>
