---
interface Props {
  name: string;
  level?: string;
}

const { name, level } = Astro.props;

// Minimalist Tech Icons (Simplified SVG paths)
const icons: Record<string, string> = {
  'power bi': 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
  tableau: 'M12 2L2 22h20L12 2z',
  looker: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
  google: 'M18 10h-4V7a2 2 0 00-2-2H8a2 2 0 00-2 2v10a2 2 0 002 2h4a2 2 0 002-2v-3',
  dax: 'M4 7V4h16v3M9 20h6M12 4v16',
  python: 'M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z',
  scikit: 'M12 3v10M12 3L7 8M12 3l5 5M12 21v-4M12 21l-3-3M12 21l3-3',
  hugging: 'M12 8a4 4 0 100 8 4 4 0 000-8z M2 12h2M20 12h2M12 2v2M12 20v2',
  mlflow: 'M22 12h-4l-3 9L9 3l-3 9H2',
  sql: 'M12 2v20M2 12h20M2 5l20 14M2 19L22 5',
  r: 'M12 2L2 22h20L12 2zm0 5l5 10H7l5-10z',
  jupyter: 'M12 22a10 10 0 100-20 10 10 0 000 20z M12 6v12M6 12h12',
  plotly: 'M3 3v18h18M7 16l4-4 4 4 6-6',
  airflow: 'M12 12L2 12M12 12L12 2M12 12L22 12M12 12L12 22',
  dbt: 'M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z',
  ssis: 'M7 12l5 5 5-5M7 7l5 5 5-5',
  azure: 'M2 22l10-20 10 20H2z',
  aws: 'M12 2L2 7l10 5 10-5-10-5z M2 17l10 5 10-5',
  docker: 'M22 7h-4V3h-4v4H10V3H6v4H2v14h20V7z',
  git: 'M12 22a10 10 0 100-20 10 10 0 000 20z M12 18l-4-4 4-4M12 14h6',
  ux: 'M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z',
  machine: 'M12 2v20M2 12h20',
};

const searchName = name.toLowerCase();
const iconKey = Object.keys(icons).find((key) => searchName.includes(key));
const iconPath = iconKey ? icons[iconKey] : null;

// Dynamic Width Calculation
let percentage = '40%';
if (level) {
  const match = level.match(/(\d+)%/);
  if (match) {
    percentage = `${match[1]}%`;
  } else if (
    level.toLowerCase().includes('avanzado') ||
    level.toLowerCase().includes('advanced') ||
    level.toLowerCase().includes('destacado')
  ) {
    percentage = '90%';
  } else if (
    level.toLowerCase().includes('intermedio') ||
    level.toLowerCase().includes('intermediate')
  ) {
    percentage = '65%';
  } else if (level.toLowerCase().includes('en curso') || level.toLowerCase().includes('familiar')) {
    percentage = '30%';
  }
}
---

<div
  class="group relative flex flex-col gap-1.5 w-full mb-3 cursor-help p-2 rounded-lg hover:bg-white/[0.02] transition-colors border border-transparent hover:border-white/5"
>
  <!-- Tooltip -->
  <div
    class="absolute -top-8 left-1/2 -translate-x-1/2 bg-[#0D0D1F] text-[8px] font-mono text-blue-300 px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-20 whitespace-nowrap border border-blue-500/30 shadow-[0_0_20px_rgba(59,130,246,0.2)]"
  >
    <span class="text-blue-500 mr-1">></span>SYSTEM_STATUS: <span class="text-cyan-400"
      >OPTIMIZED</span
    > | {percentage}
  </div>

  <div class="flex justify-between items-center px-0.5">
    <div class="flex items-center gap-2">
      {
        iconPath && (
          <svg
            class="w-3.5 h-3.5 text-blue-500 group-hover:text-cyan-400 transition-colors drop-shadow-[0_0_5px_rgba(59,130,246,0.5)]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d={iconPath} />
          </svg>
        )
      }
      <span
        class="text-[11px] font-bold uppercase tracking-widest text-slate-300 group-hover:text-white transition-colors"
        >{name}</span
      >
    </div>
    {
      level && (
        <span class="text-[9px] font-mono text-slate-500 group-hover:text-blue-400 transition-colors uppercase tracking-tighter">
          {level}
        </span>
      )
    }
  </div>
  <div
    class="h-1 w-full bg-slate-800/30 rounded-full overflow-hidden border border-white/5 relative"
  >
    <div
      class="h-full bg-gradient-to-r from-blue-600 via-cyan-500 to-blue-400 shadow-[0_0_15px_rgba(34,211,238,0.4)] transition-all duration-1000 ease-out relative"
      style={`width: ${percentage}`}
    >
      <div
        class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent animate-[shimmer_2s_infinite]"
      >
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes shimmer {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(100%);
    }
  }
</style>
