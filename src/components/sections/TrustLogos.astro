---
const logos = [
  { name: 'Adecco', src: '/AndresBI/Adecco.svg' },
  { name: 'BAT', src: '/AndresBI/BAT.svg' },
  { name: 'Beiersdorf', src: '/AndresBI/Beiersdorf.svg' },
  { name: 'Terpel', src: '/AndresBI/terpel.svg' },
  { name: 'Corficolombiana', src: '/AndresBI/corfi1.svg' },
];
---

<section class="py-10 bg-neutral-900/50">
  <div class="container mx-auto px-4">
    <p class="text-center text-[10px] md:text-xs font-semibold text-neutral-500 uppercase tracking-[0.2em] mb-8">
      Empresas que han confiado en mi trabajo
    </p>
    
    <div class="flex flex-wrap justify-center items-center gap-6 md:gap-12 opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
      {logos.map((logo) => (
        <div class="flex items-center justify-center p-2">
          <img 
            src={logo.src} 
            alt={`Logo de ${logo.name}`} 
            class={`${logo.name === 'Corficolombiana' ? 'h-10 md:h-14' : 'h-7 md:h-10'} w-auto object-contain brightness-0 invert`}
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    position: relative;
    overflow: hidden;
  }

  /* Efecto de desvanecimiento en los bordes para un look más moderno */
  section::before,
  section::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 100px;
    z-index: 2;
    pointer-events: none;
  }

  section::before {
    left: 0;
    background: linear-gradient(to right, #080813, transparent);
  }

  section::after {
    right: 0;
    background: linear-gradient(to left, #080813, transparent);
  }
</style>
