---
const currentPath = Astro.url.pathname;
const isEn = currentPath.includes('/en');

const content = {
  subtitle: isEn ? "Let's Create Something" : "Creemos Algo Juntos",
  description: isEn 
    ? "Every tattoo is a collaboration. Tell me about your project and let's create something you'll wear with pride for a lifetime."
    : "Cada tatuaje es una colaboración. Cuéntame sobre tu proyecto y creemos algo que llevarás con orgullo toda la vida.",
  title: "BOOKING",
  formTitle: isEn ? "BOOK YOUR SESSION" : "RESERVA TU SESIÓN",
  submit: isEn ? "SEND MESSAGE" : "ENVIAR MENSAJE",
  labels: {
    name: isEn ? "Name" : "Nombre",
    email: isEn ? "Email" : "Correo Electrónico",
    phone: isEn ? "Phone (optional)" : "Teléfono (opcional)",
    message: isEn ? "Tell me about your project" : "Cuéntame sobre tu proyecto",
    placeholder_name: "Your full name",
    placeholder_email: "your@email.com",
    placeholder_phone: "+57 300 000 0000",
    placeholder_message: isEn ? "Describe your tattoo idea, style preferences, placement, size..." : "Describe tu idea de tatuaje, estilo preferido, ubicación, tamaño..."
  },
  contact: {
    title: isEn ? "GET IN TOUCH" : "CONTACTO",
    email: "paulangelstattoo@gmail.com",
    phone: "+34 600 000 000",
    location: isEn ? "Madrid, Spain" : "Madrid, España",
    follow: isEn ? "Follow on Instagram" : "Sígueme en Instagram",
    social: {
      instagram: "@paulaangels",
      tiktok: "@paulaangels"
    }
  },
  steps: {
    1: isEn ? "Share your idea" : "Comparte tu idea",
    2: isEn ? "Receive quote" : "Recibe cotización",
    3: isEn ? "Book session" : "Reserva sesión"
  }
};
---

<section class="relative w-full bg-surface-container-lowest py-20 md:py-28 overflow-hidden">
  <!-- Grain texture overlay -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-8">
    <div class="flex flex-col items-center">
      
      <!-- Seccion 1: Título Principal (RESERVA TU SESIÓN) -->
      <div class="text-center mb-10 md:mb-16">
        <h2 class="font-display text-white text-4xl md:text-6xl uppercase tracking-[4px] mb-4">{content.formTitle}</h2>
        <div class="w-20 h-px mx-auto bg-gold/50"></div>
      </div>

      <!-- Seccion 2: Intro (Creemos Algo Juntos + Descripcion) -->
      <div class="text-center max-w-2xl mb-12 md:mb-20">
        <h3 class="font-display text-[#ffabf1] text-2xl md:text-3xl uppercase tracking-[0.1em] mb-4">{content.subtitle}</h3>
        <p class="font-body text-white/50 text-sm md:text-base leading-relaxed">
          {content.description}
        </p>
      </div>

      <!-- Seccion 3: Iconos de Contacto (Centered Stack) -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-16 mb-20 text-center w-full">
        <!-- Location -->
        <div class="flex flex-col items-center gap-3 group">
          <span class="material-symbols-outlined text-gold text-5xl group-hover:scale-110 transition-transform">location_on</span>
          <div class="flex flex-col">
            <span class="font-display text-white text-[10px] uppercase tracking-widest opacity-40 mb-1">LOCATION</span>
            <span class="font-body text-white text-sm tracking-wide">{content.contact.location}</span>
          </div>
        </div>
        <!-- Email -->
        <div class="flex flex-col items-center gap-3 group">
          <span class="material-symbols-outlined text-gold text-5xl group-hover:scale-110 transition-transform">mail</span>
          <div class="flex flex-col">
            <span class="font-display text-white text-[10px] uppercase tracking-widest opacity-40 mb-1">EMAIL</span>
            <a href={`mailto:${content.contact.email}`} class="font-body text-white text-sm hover:text-gold transition-colors">{content.contact.email}</a>
          </div>
        </div>
        <!-- Instagram -->
        <div class="flex flex-col items-center gap-3 group">
          <span class="material-symbols-outlined text-gold text-5xl group-hover:scale-110 transition-transform">public</span>
          <div class="flex flex-col">
            <span class="font-display text-white text-[10px] uppercase tracking-widest opacity-40 mb-1">INSTAGRAM</span>
            <a href="https://instagram.com/paulaangels" target="_blank" class="font-body text-white text-sm hover:text-gold transition-colors">{content.contact.social.instagram}</a>
          </div>
        </div>
      </div>

      <!-- Seccion 4: Formulario de Contacto (Premium Center) -->
      <div class="w-full max-w-2xl bg-[#090d1d] border-t border-l border-white/5 p-8 md:p-12 shadow-2xl relative">
        <form class="space-y-8" method="POST" action="/api/contact">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
              <label class="block font-body text-primary text-[10px] uppercase tracking-widest text-center md:text-left">{content.labels.name}</label>
              <input type="text" name="name" required class="w-full text-center md:text-left" />
            </div>
            <div class="space-y-2">
              <label class="block font-body text-primary text-[10px] uppercase tracking-widest text-center md:text-left">{content.labels.email}</label>
              <input type="email" name="email" required class="w-full text-center md:text-left" />
            </div>
          </div>
          <div class="space-y-2">
            <label class="block font-body text-primary text-[10px] uppercase tracking-widest text-center md:text-left">{content.labels.message}</label>
            <textarea name="message" rows="4" required class="w-full resize-none text-center md:text-left"></textarea>
          </div>
          <button type="submit" class="btn-primary w-full py-5 text-xs tracking-[0.4em] font-bold">
            {content.submit}
          </button>
        </form>
      </div>

      <!-- Seccion 5: Info adicional (Process Steps) -->
      <div class="w-full max-w-2xl mt-16 pt-8 border-t border-white/5">
        <h4 class="font-display text-white text-xs uppercase tracking-[0.2em] mb-8 opacity-40 text-center">PROCESS</h4>
        <div class="flex flex-col md:flex-row justify-center items-center gap-10 md:gap-16">
          {[1, 2, 3].map((num) => (
            <div class="flex flex-col items-center gap-3">
              <span class="font-display text-gold text-2xl leading-none">{num}</span>
              <span class="font-body text-white/60 text-[10px] uppercase tracking-[0.2em] leading-tight text-center max-w-[120px]">{(content.steps as any)[num]}</span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
