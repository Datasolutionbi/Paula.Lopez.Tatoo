---
import { SITE } from '../../data/site';
interface Props {
  isEn?: boolean;
}
const { isEn = false } = Astro.props;
---
<section id="contacto" class="section-padding">
  <div class="container-custom">
    <div class="max-w-2xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-[10px] font-mono text-blue-400 mb-6 uppercase tracking-widest animate-pulse">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
        Ready_to_Transmmit
      </div>
      <h2 class="text-section mb-4">{isEn ? "Let's Work Together" : "¿Trabajamos Juntos?"}</h2>
      <p class="text-lg text-slate-400 mb-10 text-balance">
        {isEn 
          ? "Available for BI, data analytics, and machine learning projects. If you have an interesting project, let's talk!" 
          : "Estoy disponible para proyectos de BI, analítica de datos y machine learning. Si tienes un proyecto interesante, ¡hablemos!"}
      </p>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href={`mailto:${SITE.email}`} class="btn-primary group/btn relative overflow-hidden">
          <span class="relative z-10 flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            {isEn ? 'Send Email' : 'Enviar Email'}
          </span>
        </a>
        <a href={SITE.linkedin} target="_blank" rel="noopener noreferrer" class="btn-secondary group/btn">
          <span class="relative z-10 flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            LinkedIn Portal
          </span>
        </a>
      </div>
    </div>
  </div>
</section>
