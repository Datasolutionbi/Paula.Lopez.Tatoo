---
const currentPath = Astro.url.pathname;
const isEn = currentPath.includes('/en');

const content = {
  title: isEn ? "SECURE YOUR SPOT" : "ASEGURA TU LUGAR",
  subtitle: isEn ? "SPOTS ARE EXTREMELY LIMITED" : "CUPOS EXTREMADAMENTE LIMITADOS",
  description: isEn 
    ? "Due to high demand and frequent travel, please provide detailed information about your project. I will review and respond within 24 hours."
    : "Debido a la alta demanda y viajes constantes, proporciona información detallada sobre tu proyecto. Revisaré y responderé en menos de 24 horas.",
  submit: isEn ? "SEND BOOKING REQUEST" : "ENVIAR SOLICITUD DE RESERVA",
  labels: {
    name: isEn ? "Full Name" : "Nombre Completo",
    phone: isEn ? "Phone Number" : "Teléfono / WhatsApp",
    placement: isEn ? "Placement & Size" : "Ubicación y Tamaño",
    description: isEn ? "Project Description" : "Descripción del Proyecto",
    placeholder_name: "MARCO ROJAS",
    placeholder_phone: "+57 300 000 0000",
    placeholder_desc: isEn ? "DESCRIBE YOUR IDEA IN DETAIL (STYLE, MEANING, ELEMENTS...)" : "DESCRIBE TU IDEA EN DETALLE (ESTILO, SIGNIFICADO, ELEMENTOS...)"
  },
  steps: {
    1: isEn ? "Detail your idea" : "Detalla tu idea",
    2: isEn ? "Select placement" : "Elige la ubicación",
    3: isEn ? "Get quoted" : "Recibe cotización"
  },
  system: isEn ? "SYSTEM ONLINE • BOOKING NOW" : "SISTEMA ONLINE • AGENDA ABIERTA",
  options: {
    body: isEn ? ["BACK", "ARM", "LEG", "CHEST"] : ["ESPALDA", "BRAZO", "PIERNA", "PECHO"],
    size: isEn ? ["SMALL (<10CM)", "MEDIUM (10-20CM)", "LARGE (>20CM)", "FULL SLEEVE"] : ["PEQUEÑO (<10CM)", "MEDIANO (10-20CM)", "GRANDE (>20CM)", "MANGA COMPLETA"]
  }
};
---

<div class="relative w-full h-full flex flex-col md:flex-row overflow-hidden bg-white border border-black/5 rounded-3xl">
  <!-- Booking Info Side (Visual & Text) -->
  <div class="w-full md:w-5/12 p-12 md:p-16 lg:p-20 bg-studio-purple flex flex-col justify-center relative min-h-[450px] md:min-h-0">
    <!-- Background Texture Contrast -->
    <div class="absolute inset-0 opacity-15 pointer-events-none mix-blend-overlay">
      <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/clean-gray-paper.png')]"></div>
    </div>

    <div class="relative z-10">
      <div class="inline-block px-5 py-1.5 bg-white/10 backdrop-blur-md border border-white/20 text-[10px] font-bold uppercase tracking-[0.4em] mb-12 text-white">
        {content.subtitle}
      </div>
      
      <h2 class="flex flex-col mb-12 leading-[0.8]">
        <span class="font-serif-editorial text-6xl md:text-7xl lg:text-8xl text-white italic opacity-90 -ml-1">
          {isEn ? "Leave" : "Deja"}
        </span>
        <span class="text-white font-sans font-black text-7xl md:text-8xl lg:text-9xl tracking-tighter uppercase">
          {isEn ? "Mark" : "Marca"}
        </span>
      </h2>
      
      <p class="font-sans text-[11px] md:text-xs font-bold uppercase tracking-[0.25em] opacity-60 leading-relaxed max-w-sm mb-20 text-white">
        {content.description}
      </p>

      <div class="grid grid-cols-1 gap-10">
        {[1, 2, 3].map((num) => (
          <div class="flex items-center gap-8 group">
            <div class="relative flex flex-col items-center">
              <span class="text-sm font-serif-editorial italic text-white mb-1">{num}</span>
              <div class="w-px h-8 bg-white/20 transition-all duration-300 group-last:hidden"></div>
            </div>
            <span class="text-[11px] font-bold uppercase tracking-[0.25em] opacity-50 text-white group-hover:opacity-100 transition-opacity">
              {(content.steps as any)[num]}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Form Side -->
  <div class="w-full md:w-7/12 p-10 md:p-16 lg:p-20 bg-white flex flex-col justify-center">
    <form class="space-y-10">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 md:gap-12">
        <div class="space-y-3">
          <label class="block text-[9px] uppercase tracking-[0.3em] font-bold opacity-30 text-black">{content.labels.name}</label>
          <input 
            type="text"
            placeholder={content.labels.placeholder_name}
            class="w-full bg-transparent border-b border-black/10 focus:border-studio-purple rounded-none py-3 font-sans text-[11px] uppercase tracking-widest outline-none transition-all duration-500 text-black placeholder:text-black/10"
          />
        </div>
        <div class="space-y-3">
          <label class="block text-[9px] uppercase tracking-[0.3em] font-bold opacity-30 text-black">{content.labels.phone}</label>
          <input 
            type="tel"
            placeholder={content.labels.placeholder_phone}
            class="w-full bg-transparent border-b border-black/10 focus:border-studio-purple rounded-none py-3 font-sans text-[11px] uppercase tracking-widest outline-none transition-all duration-500 text-black placeholder:text-black/10"
          />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 md:gap-12">
        <div class="space-y-3">
          <label class="text-[9px] uppercase tracking-[0.3em] font-bold opacity-30 text-black">{content.labels.placement}</label>
          <select class="w-full bg-transparent border-b border-black/10 focus:border-studio-purple rounded-none py-3 font-sans text-[11px] uppercase tracking-widest outline-none transition-all duration-500 appearance-none cursor-pointer text-black/60">
            {content.options.body.map(opt => <option>{opt}</option>)}
          </select>
        </div>
        <div class="space-y-3">
          <label class="text-[9px] uppercase tracking-[0.3em] font-bold opacity-30 text-black">Tamaño</label>
          <select class="w-full bg-transparent border-b border-black/10 focus:border-studio-purple rounded-none py-3 font-sans text-[11px] uppercase tracking-widest outline-none transition-all duration-500 appearance-none cursor-pointer text-black/60">
            {content.options.size.map(opt => <option>{opt}</option>)}
          </select>
        </div>
      </div>

      <div class="space-y-3">
        <label class="text-[9px] uppercase tracking-[0.3em] font-bold opacity-30 text-black">{content.labels.description}</label>
        <textarea 
          rows="3" 
          placeholder={content.labels.placeholder_desc}
          class="w-full bg-transparent border-b border-black/10 focus:border-studio-purple rounded-none py-3 font-sans text-[11px] uppercase tracking-widest outline-none transition-all duration-500 resize-none text-black placeholder:text-black/10"
        ></textarea>
      </div>

      <div class="pt-6">
        <button type="submit" class="group relative w-full bg-studio-purple text-white py-6 overflow-hidden transition-all duration-500 hover:shadow-2xl hover:shadow-purple-900/20 active:scale-[0.98]">
          <span class="relative z-10 text-[10px] font-black uppercase tracking-[0.4em]">{content.submit}</span>
          <div class="absolute inset-0 bg-black translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
        </button>
      </div>

      <div class="flex items-center justify-center gap-4 pt-4">
         <div class="w-1.5 h-1.5 rounded-full bg-studio-purple animate-pulse"></div>
         <span class="text-[9px] uppercase tracking-[0.5em] font-bold opacity-30">{content.system}</span>
      </div>
    </form>
  </div>
</div>
