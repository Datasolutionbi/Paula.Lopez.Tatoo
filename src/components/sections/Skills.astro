---
import SkillRadar from '../SkillRadar.astro';
import SynapticLines from '../SynapticLines.astro';
import CareerDashboard from '../CareerDashboard.astro';
import SkillBadge from '../SkillBadge.astro';

interface Props {
  isEn?: boolean;
  skills: any;
}
const { isEn = false, skills } = Astro.props;
---
<section id="habilidades" class="section-padding section-glow-container reveal-blur relative">
  <SynapticLines />
  <div class="container-custom relative z-10">
    <h2 class="text-section mb-12 text-center">{isEn ? 'Technical Stack' : 'Stack Técnico'}</h2>
    
    <div class="grid lg:grid-cols-12 gap-12 items-start relative">
      <div class="lg:col-span-5 order-2 lg:order-1 flex flex-col gap-8 relative z-10 items-center justify-center">
        <div class="w-full mb-8">
          <SkillRadar skills={skills} />
        </div>
        <div class="w-full">
          <CareerDashboard />
        </div>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2 space-y-6">
        <div class="grid md:grid-cols-2 gap-6">
          {Object.entries(skills).map(([key, category]: [string, any]) => (
            <div class="card p-5 skill-category-card">
              <h3 class="text-lg font-semibold mb-4 text-blue-100">{category.title}</h3>
              <div class="flex flex-wrap gap-2">
                {category.tools.map((tool: any) => (
                  <SkillBadge name={tool.name} level={tool.level === 'Avanzado' && isEn ? 'Advanced' : tool.level === 'Intermedio' && isEn ? 'Intermediate' : tool.level === 'Básico' && isEn ? 'Basic' : tool.level} />
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
