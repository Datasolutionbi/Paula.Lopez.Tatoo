---
import TattooSeparator from '../ui/TattooSeparator.astro';
const currentPath = Astro.url.pathname;
const isEn = currentPath.includes('/en');

const content = {
  title: isEn ? "STORIES" : "HISTORIAS",
  lead: isEn 
    ? "BEYOND THE INK, EVERY PIECE HAS A SOUL."
    : "MÁS ALLÁ DE LA TINTA, CADA PIEZA TIENE ALMA.",
};
---

<div class="relative w-full py-12 bg-white overflow-hidden group">
  
  <!-- Decorative Background Text (Watermark) -->
  <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 select-none pointer-events-none z-0">
    <span class="font-display text-[10rem] md:text-[16rem] text-black/[0.02] whitespace-nowrap">STUDIO</span>
  </div>

  <!-- Content -->
  <div class="relative z-10 container-custom flex flex-col items-center justify-center text-center">
    
    <div class="mb-4">
      <h3 class="font-display text-4xl md:text-6xl text-black tracking-tighter uppercase mb-3 group-hover:scale-105 transition-transform duration-700">{content.title}</h3>
      <div class="w-24 h-0.5 bg-studio-purple/50 mx-auto"></div>
    </div>
    
    <p class="font-modern text-xs md:text-sm font-bold uppercase tracking-[0.3em] text-black/60 mb-8 leading-relaxed max-w-lg">
      {content.lead}
    </p>

    <a href="/blog" class="group/btn relative inline-flex items-center gap-3 px-6 py-3 bg-transparent border border-black/10 hover:border-studio-purple transition-colors duration-300 overflow-hidden">
      <span class="font-modern text-[10px] font-black uppercase tracking-[0.3em] text-black group-hover/btn:text-studio-purple transition-colors z-10">
        READ STORIES
      </span>
      <div class="absolute inset-0 bg-studio-purple/5 transform -translate-x-full group-hover/btn:translate-x-0 transition-transform duration-500"></div>
    </a>

    <!-- Subtle Ink Drop Decoration -->
    <div class="mt-8 w-full max-w-xs mx-auto">
      <TattooSeparator variant="needle" />
    </div>

  </div>
</div>
