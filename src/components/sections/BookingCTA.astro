---
const { isEn = false } = Astro.props;

const content = {
  title: isEn ? "DO YOU WANT TO GET IN OUR BOOKS? BOOKING NOW!" : "¿QUIERES ESTAR EN MIS LIBROS? ¡RESERVANDO AHORA!",
  subtitle: isEn 
    ? "SPOTS ARE LIMITED DUE TO JOSE ALWAYS TRAVELING THROUGH DIFFERENT CITIES AROUND THE COUNTRY. PLEASE COMPLETE THIS FORM AND YOU WILL RECEIVE ALL THE INFORMATION IN LESS THAN 24HRS."
    : "LOS CUPOS SON LIMITADOS YA QUE JOSE SIEMPRE VIAJA POR DIFERENTES CIUDADES DEL PAÍS. POR FAVOR COMPLETA ESTE FORMULARIO Y RECIBIRÁS TODA LA INFORMACIÓN EN MENOS DE 24 HORAS.",
  follow: isEn ? "FOLLOW US ON OUR SOCIAL MEDIA" : "SÍGUENOS EN MIS REDES",
};

import TattooSeparator from '../ui/TattooSeparator.astro';
---

<section class="py-12 bg-white relative overflow-hidden">
  <TattooSeparator variant="minimal" class="absolute top-0 left-0 w-full" />
  <div class="container-custom text-center relative z-10 reveal-effect">
    <h2 class="text-4xl md:text-7xl font-sans font-black text-black mb-10 leading-tight uppercase tracking-tight">
      {content.title}
    </h2>
    
    <p class="font-modern text-[10px] md:text-xs font-bold uppercase tracking-[0.4em] text-black/40 max-w-4xl mx-auto mb-16 leading-loose px-4">
      {content.subtitle}
    </p>

    <div class="space-y-8">
      <span class="block text-[10px] uppercase tracking-[0.5em] font-black text-black/60">
        {content.follow}
      </span>
      
      <div class="flex items-center justify-center gap-8">
        <!-- Facebook -->
        <a href="#" aria-label="Facebook" class="text-black/50 hover:text-studio-purple transition-transform hover:scale-125 magnetic-wrap">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-facebook"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
        <!-- Instagram -->
        <a href="#" aria-label="Instagram" class="text-black/50 hover:text-studio-purple transition-transform hover:scale-125 magnetic-wrap">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
        </a>
        <!-- YouTube -->
        <a href="#" aria-label="YouTube" class="text-black/50 hover:text-studio-purple transition-transform hover:scale-125 magnetic-wrap">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-youtube"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"></path><path d="m10 15 5-3-5-3z"></path></svg>
        </a>
        <!-- TikTok -->
        <a href="#" aria-label="TikTok" class="text-black/50 hover:text-studio-purple transition-transform hover:scale-125 magnetic-wrap">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-music"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
        </a>
        <!-- Reddit (Simple) -->
        <a href="#" aria-label="Reddit" class="text-black/50 hover:text-studio-purple transition-transform hover:scale-125 magnetic-wrap">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-orbit"><circle cx="12" cy="12" r="3"></circle><circle cx="19" cy="5" r="2"></circle><circle cx="5" cy="19" r="2"></circle><path d="M10.4 21.9a10 10 0 0 0 9.2-12.4"></path><path d="M1.3 14.3a10 10 0 0 0 12.4 9.2"></path><path d="M13.6 2.1a10 10 0 0 0-9.2 12.4"></path><path d="M22.7 9.7a10 10 0 0 0-12.4-9.2"></path></svg>
        </a>
      </div>
    </div>
    <div class="relative w-full py-12 px-6 overflow-hidden text-center group bg-studio-purple text-white"></div>
  </div>
</section>
