---
interface Props {
  title: string;
  description: string;
  tech: string[];
  github?: string;
  demo?: string;
  slug?: string;
}

const { title, description, tech, github, demo, slug } = Astro.props;
---

<article class="card group flex flex-col h-full project-card overflow-hidden transition-all duration-300" data-tech={tech.join(',')}>
  <div class="glass-card-glow"></div>
  <!-- Visual Tech Decor -->
  <div class="absolute top-0 right-0 w-24 h-24 opacity-10 group-hover:opacity-30 transition-opacity pointer-events-none">
    <svg class="w-full h-full text-blue-400" viewBox="0 0 100 100">
      <path d="M10 10 L90 10 L90 90 L10 90 Z" fill="none" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2" />
      <circle cx="50" cy="50" r="30" fill="none" stroke="currentColor" stroke-width="0.2" />
      <path d="M20 50 L80 50 M50 20 L50 80" stroke="currentColor" stroke-width="0.2" />
    </svg>
  </div>

  <div class="mb-3">
    <span class="text-[10px] font-mono text-blue-500/50 block mb-1">// project_initialization</span>
    <h3 class="text-xl font-bold group-hover:text-blue-400 transition-colors font-mono tracking-tight">
      <span class="text-blue-400">fn</span> {title}()
    </h3>
  </div>
  
  <p class="text-slate-400 mb-4 line-clamp-3 text-sm font-sans italic border-l border-blue-500/20 pl-3">
    <span class="text-slate-600 not-italic mr-1">/*</span> {description} <span class="text-slate-600 not-italic ml-1">*/</span>
  </p>
  
  <!-- Tech Stack -->
  <div class="flex flex-wrap gap-2 mb-6">
    {tech.map((item) => (
      <span class="badge-secondary text-[10px]">
        {item}
      </span>
    ))}
  </div>
  
  <!-- Links -->
  <div class="flex gap-4 mt-auto pt-4 border-t border-white/5">
    {github && (
      <a 
        href={github} 
        target="_blank" 
        rel="noopener noreferrer"
        class="text-xs text-slate-400 hover:text-blue-400 transition-colors inline-flex items-center gap-1.5 font-medium"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
        GitHub
      </a>
    )}
    
    {demo && (
      <a 
        href={demo} 
        target="_blank" 
        rel="noopener noreferrer"
        class="text-xs text-slate-400 hover:text-cyan-400 transition-colors inline-flex items-center gap-1.5 font-medium"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
        Demo
      </a>
    )}
  </div>
</article>

<script>
  function initProjectCards() {
    const cards = document.querySelectorAll('.project-card');
    cards.forEach(card => {
      card.addEventListener('mousemove', (e) => {
        if (card instanceof HTMLElement) {
          const rect = card.getBoundingClientRect();
          const x = ((e as MouseEvent).clientX - rect.left);
          const y = ((e as MouseEvent).clientY - rect.top);
          
          card.style.setProperty('--mouse-x', `${x}px`);
          card.style.setProperty('--mouse-y', `${y}px`);
        }
      });
    });
  }

  // Initialize on load
  initProjectCards();
  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initProjectCards);
</script>
