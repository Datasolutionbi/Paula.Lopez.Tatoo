---
---

<div class="card p-8 bg-[#0D0D1F]/80 border-blue-500/20 shadow-[0_0_50px_rgba(59,130,246,0.05)]">
  <div class="flex items-center justify-between mb-8">
    <h4 class="text-xs font-mono text-blue-400 uppercase tracking-[0.2em]">Career_Analytics_v2</h4>
    <div class="flex gap-2">
      <div class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></div>
      <span class="text-[8px] font-mono text-slate-500 uppercase">Live_Analysis</span>
    </div>
  </div>

  <div class="space-y-8">
    <!-- Skill Distribution (Radar-like simulation with CSS) -->
    <div class="relative h-40 flex items-center justify-center">
      <div class="absolute inset-0 border border-blue-500/10 rounded-full animate-[spin_20s_linear_infinite]"></div>
      <div class="absolute inset-4 border border-blue-500/10 rounded-full animate-[spin_15s_linear_infinite_reverse]"></div>
      
      <svg class="w-full h-full max-h-32 drop-shadow-[0_0_15px_rgba(59,130,246,0.3)]" viewBox="0 0 100 100">
        <!-- Background Hexagon -->
        <polygon points="50,5 93.3,30 93.3,80 50,105 6.7,80 6.7,30" class="fill-none stroke-white/5" transform="scale(0.8) translate(12, 12)" />
        <!-- Data Polygon -->
        <polygon 
          points="50,20 80,40 75,70 50,85 25,70 20,40" 
          class="fill-blue-500/20 stroke-blue-400" 
          stroke-width="1"
          transform="scale(0.8) translate(12, 12)"
        >
          <animate attributeName="points" dur="5s" repeatCount="indefinite"
            values="50,20 80,40 75,70 50,85 25,70 20,40; 50,15 85,35 80,75 50,90 20,75 15,35; 50,20 80,40 75,70 50,85 25,70 20,40" />
        </polygon>
        <!-- Axes -->
        <line x1="50" y1="10" x2="50" y2="90" class="stroke-white/5" />
        <line x1="10" y1="30" x2="90" y2="70" class="stroke-white/5" />
        <line x1="10" y1="70" x2="90" y2="30" class="stroke-white/5" />
      </svg>
      
      <!-- Labels -->
      <span class="absolute top-0 text-[8px] font-mono text-blue-300">BI</span>
      <span class="absolute bottom-0 text-[8px] font-mono text-blue-300">ML</span>
      <span class="absolute right-0 top-1/2 -translate-y-1/2 text-[8px] font-mono text-blue-300">UX</span>
      <span class="absolute left-0 top-1/2 -translate-y-1/2 text-[8px] font-mono text-blue-300">IA</span>
    </div>

    <!-- Metrics Grid -->
    <div class="grid grid-cols-2 gap-4">
      <div class="p-3 bg-blue-500/5 border border-white/5 rounded-lg">
        <div class="text-[8px] text-slate-500 uppercase mb-1">Impact_Score</div>
        <div class="text-xl font-bold text-white font-mono">9.8<span class="text-blue-500 text-xs">/10</span></div>
      </div>
      <div class="p-3 bg-cyan-500/5 border border-white/5 rounded-lg">
        <div class="text-[8px] text-slate-500 uppercase mb-1">Efficiency</div>
        <div class="text-xl font-bold text-white font-mono">124<span class="text-cyan-500 text-xs">%</span></div>
      </div>
    </div>

    <!-- Growth Line -->
    <div class="space-y-2">
      <div class="flex justify-between text-[8px] font-mono text-slate-500">
        <span>PROFESSIONAL_GROWTH</span>
        <span class="text-green-400">+45% YOY</span>
      </div>
      <div class="h-12 w-full bg-blue-500/5 rounded border border-white/5 p-1 flex items-end gap-0.5">
        <div class="flex-1 bg-blue-500/20 h-[20%] animate-[pulse_2s_infinite]"></div>
        <div class="flex-1 bg-blue-500/30 h-[35%] animate-[pulse_2.2s_infinite]"></div>
        <div class="flex-1 bg-blue-500/40 h-[30%] animate-[pulse_1.8s_infinite]"></div>
        <div class="flex-1 bg-blue-500/50 h-[50%] animate-[pulse_2.5s_infinite]"></div>
        <div class="flex-1 bg-blue-500/60 h-[45%] animate-[pulse_2.1s_infinite]"></div>
        <div class="flex-1 bg-blue-500/70 h-[70%] animate-[pulse_2.3s_infinite]"></div>
        <div class="flex-1 bg-blue-500/80 h-[65%] animate-[pulse_1.9s_infinite]"></div>
        <div class="flex-1 bg-blue-500/90 h-[90%] animate-[pulse_2.4s_infinite]"></div>
      </div>
    </div>
  </div>
</div>
