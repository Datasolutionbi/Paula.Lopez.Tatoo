---
const currentYear = new Date().getFullYear();
import TattooSeparator from './ui/TattooSeparator.astro';
---

<footer class="py-20 bg-white border-t border-black/5">
  <div class="px-6 md:px-12 max-w-[1400px] mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-center gap-12 text-center md:text-left">
      
      <!-- Brand -->
      <div class="flex flex-col gap-2">
        <p class="text-[10px] uppercase tracking-widest text-black/30 font-bold">
          &copy; {currentYear} Paula López / Tattoocaro
        </p>
      </div>

      <!-- Links -->
      <nav class="flex flex-wrap justify-center gap-8 md:gap-12">
        {['Privacy Policy', 'Terms of Service', 'Aftercare', 'Press Kit'].map(link => (
          <a href="#" class="text-[10px] font-black uppercase tracking-[0.2em] text-black/40 hover:text-black transition-colors">
            {link}
          </a>
        ))}
      </nav>

      <!-- Social -->
      <div class="flex items-center gap-6">
        <a href="#" class="text-black opacity-40 hover:opacity-100 transition-opacity">
          <span class="text-xs font-black uppercase tracking-widest">Instagram</span>
        </a>
        <a href="#" class="text-black opacity-40 hover:opacity-100 transition-opacity">
          <span class="text-xs font-black uppercase tracking-widest">Youtube</span>
        </a>
      </div>
    </div>
  </div>
</footer>
