---
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<footer class="w-full bg-[#00010d] border-t border-outline-variant/10 relative overflow-hidden">
    <!-- Luz de fondo sutil -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-primary/5 blur-[100px] rounded-full pointer-events-none"></div>

    <div class="max-w-[1400px] mx-auto px-8 lg:px-24">
        <div class="py-20 lg:py-32 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-16 lg:gap-8 border-b border-outline-variant/10">
            
            <div class="lg:col-span-4 flex flex-col gap-6">
                <a href={`${base}/`} class="hover:opacity-80 transition-opacity flex flex-col items-start gap-4">
                    <img src={`${base}/paula%20lopez.png`} alt="Paula Lopez Logo" class="h-16 w-auto object-contain" />
                    <span class="font-headline text-[8px] tracking-[0.4em] text-[#ffabf1] uppercase block">Synthetic Cathedral</span>
                </a>
                <p class="font-body italic text-sm text-on-surface-variant opacity-70 leading-relaxed mt-2 max-w-sm" data-i18n="footer.description">
                    Localizados en el corazón de las sombras. Las citas operan estrictamente bajo curación. Un espacio de reverencia, liturgia visual y silencio artístico.
                </p>
            </div>

            <!-- Enlaces: El Santuario -->
            <div class="lg:col-span-3 flex flex-col gap-6">
                <h4 class="font-headline text-[10px] tracking-[0.3em] uppercase text-white/50">El Santuario</h4>
                <ul class="flex flex-col gap-4 list-none p-0">
                    <li><a href={`${base}/about`} class="font-headline text-xs tracking-widest text-[#9bcaff] hover:text-[#ffabf1] transition-colors uppercase" data-i18n="nav.about">Sobre Mí</a></li>
                    <li><a href={`${base}/portafolio`} class="font-headline text-xs tracking-widest text-[#9bcaff] hover:text-[#ffabf1] transition-colors uppercase" data-i18n="nav.portfolio">Portafolio</a></li>
                    <li><a href={`${base}/seminarios`} class="font-headline text-xs tracking-widest text-[#9bcaff] hover:text-[#ffabf1] transition-colors uppercase" data-i18n="nav.seminarios">Seminarios</a></li>
                    <li><a href={`${base}/faq`} class="font-headline text-xs tracking-widest text-[#9bcaff] hover:text-[#ffabf1] transition-colors uppercase" data-i18n="nav.faq">Preguntas</a></li>
                </ul>
            </div>

            <!-- Contacto & Credos -->
            <div class="lg:col-span-3 flex flex-col gap-6">
                <h4 class="font-headline text-[10px] tracking-[0.3em] uppercase text-white/50">Comunicación</h4>
                <ul class="flex flex-col gap-4 list-none p-0">
                    <li><a href={`${base}/contacto`} class="font-headline text-xs tracking-widest text-[#ffabf1] hover:text-white transition-colors uppercase border-b border-[#ffabf1]/30 pb-1 inline-block" data-i18n="nav.contact">Contacto</a></li>
                    <li><a href="https://www.instagram.com/paulaangels/" target="_blank" rel="noopener noreferrer" class="font-headline text-xs tracking-widest text-on-surface hover:text-[#ffabf1] transition-colors uppercase">Instagram</a></li>
                    <li><a href="#" class="font-headline text-xs tracking-widest text-on-surface hover:text-[#ffabf1] transition-colors uppercase">Spotify</a></li>
                </ul>
            </div>
            
        </div>

        <!-- Copyright Abajo -->
        <div class="py-8 flex flex-col md:flex-row items-center justify-between gap-4 text-center md:text-left">
            <span class="font-headline text-[9px] tracking-[0.4em] text-white/30 uppercase block">
                © MMXXIV PAULA LOPEZ. THE SYNTHETIC CATHEDRAL.
            </span>
            <div class="flex gap-6">
                <a class="font-headline text-[9px] tracking-[0.2em] text-white/30 hover:text-white/80 transition-colors uppercase" href="#">The Liturgy</a>
                <a class="font-headline text-[9px] tracking-[0.2em] text-white/30 hover:text-white/80 transition-colors uppercase" href="#">Digital Relics</a>
                <a class="font-headline text-[9px] tracking-[0.2em] text-white/30 hover:text-white/80 transition-colors uppercase" href="#">Privacy Sanctum</a>
            </div>
        </div>
    </div>
</footer>

<style>
    ul {
        list-style: none !important;
        padding-left: 0 !important;
        margin-left: 0 !important;
    }
    li {
        list-style-type: none !important;
    }
</style>
