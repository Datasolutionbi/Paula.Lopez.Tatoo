---
import { SITE } from '../data/site';
import { social } from '../data/social';

const currentYear = new Date().getFullYear();
---

<footer class="bg-[#0a0a1a] border-t border-slate-800/50 mt-12">
  <div class="container-custom py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- About -->
      <div>
        <h3 class="font-semibold text-white mb-4">{SITE.name}</h3>
        <p class="text-sm text-slate-400 mb-4">
          {SITE.tagline}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-semibold text-white mb-4">Enlaces</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="text-slate-400 hover:text-blue-400 transition-colors">Inicio</a></li>
          <li><a href="/blog" class="text-slate-400 hover:text-blue-400 transition-colors">Blog</a></li>
          <li><a href="/docs" class="text-slate-400 hover:text-blue-400 transition-colors">Documentación</a></li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h3 class="font-semibold text-white mb-4">Contacto</h3>
        <div class="flex gap-4">
          {social.map((link) => (
            <a 
              href={link.url} 
              target="_blank" 
              rel="noopener noreferrer"
              class="text-slate-400 hover:text-blue-400 transition-all duration-300 relative group/icon p-2"
              aria-label={link.name}
            >
              <div class="absolute inset-0 bg-blue-500/0 group-hover/icon:bg-blue-500/10 rounded-full blur-md transition-all duration-300"></div>
              <div class="relative z-10 group-hover/icon:drop-shadow-[0_0_8px_rgba(59,130,246,0.6)]">
                {link.icon === 'github' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                  </svg>
                )}
                {link.icon === 'linkedin' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                  </svg>
                )}
                {link.icon === 'kaggle' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M18.825 23.859c-.022.092-.117.141-.281.141h-3.139c-.187 0-.351-.082-.492-.248l-5.178-6.589-1.448 1.374v5.111c0 .235-.117.352-.351.352H5.505c-.236 0-.354-.117-.354-.352V.353c0-.233.118-.353.354-.353h2.431c.234 0 .351.12.351.353v14.343l6.203-6.272c.165-.165.33-.246.495-.246h3.239c.144 0 .236.06.285.18.046.149.034.255-.036.315l-6.555 6.344 6.836 8.507c.095.104.117.208.07.358"/>
                  </svg>
                )}
                {link.icon === 'mail' && (
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-8 pt-8 border-t border-slate-800/50 flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-mono">
      <div class="text-slate-500 flex gap-4">
        <span class="flex items-center gap-1.5"><span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span> SYS_STATUS: STABLE</span>
        <span>UPTIME: 99.99%</span>
        <span id="sys-clock"></span>
      </div>
      <p class="text-slate-500">&copy; {currentYear} {SITE.name}. Portafolio de Datos v2.0</p>
    </div>
  </div>
</footer>

<script>
  function updateClock() {
    const clock = document.getElementById('sys-clock');
    if (clock) {
      const now = new Date();
      clock.innerText = `L_TIME: ${now.getHours().toString().padStart(2, '0')}:${now.getMinutes().toString().padStart(2, '0')}:${now.getSeconds().toString().padStart(2, '0')}`;
    }
  }
  setInterval(updateClock, 1000);
  updateClock();
</script>
