---
import { SITE } from '../data/site';
import { experience, consultancy } from '../data/experience';
import { education, certifications } from '../data/education';
import { skills } from '../data/skills';
import '../styles/global.css';

const isEn = false;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CV - {SITE.name}</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg-site: #e5eaf0;
        --card-white: #ffffff;
        --card-dark: #1e293b;
        --accent: #3b82f6;
        --accent-light: #eff6ff;
        --coral: #ff7e67;
        --text-main: #0f172a;
        --text-light: #64748b;
        --radius-lg: 20px;
        --radius-md: 12px;
      }

      @media print {
        @page {
          size: letter;
          margin: 0;
        }
        body {
          background: white !important;
          padding: 0 !important;
          -webkit-print-color-adjust: exact;
        }
        .no-print {
          display: none;
        }
        .cv-wrapper {
          box-shadow: none !important;
          margin: 0 !important;
          width: 215.9mm;
          min-height: 279.4mm;
          border: none !important;
          border-radius: 0 !important;
        }
      }

      body {
        margin: 0;
        padding: 40px 20px;
        background-color: #cbd5e1;
        font-family: 'Outfit', sans-serif;
        color: var(--text-main);
        display: flex;
        justify-content: center;
      }

      .cv-wrapper {
        width: 215.9mm;
        min-height: 279.4mm;
        background-color: var(--bg-site);
        position: relative;
        padding: 30px;
        box-sizing: border-box;
        display: grid;
        grid-template-columns: 280px 1fr;
        grid-template-rows: auto 1fr;
        gap: 25px;
        border-top: 5px solid var(--accent);
        border-radius: 8px;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 0.1);
      }

      /* HEADER SECTION */
      .photo-card {
        grid-column: 1;
        background: #ced4de;
        border-radius: var(--radius-lg);
        min-height: 240px; /* Shared minimum length */
        height: 100%;
        overflow: hidden;
        border: 1px solid rgba(0, 0, 0, 0.05);
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .photo-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 15%;
      }

      .name-card {
        grid-column: 2;
        background: #ced4de;
        border-radius: var(--radius-lg);
        padding: 45px 50px;
        min-height: 240px; /* Shared minimum length */
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        border: 1px solid rgba(0, 0, 0, 0.05);
      }

      .detail-tag {
        position: absolute;
        top: 20px;
        right: 25px;
        background: #1e293b;
        color: white;
        font-size: 8px;
        padding: 5px 12px;
        border-radius: 4px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s ease;
      }
      .detail-tag:hover {
        background: #334155;
        transform: translateY(-1px);
        box-shadow: 0 6px 15px rgba(0, 0, 0, 0.2);
      }

      .name-card h1 {
        margin: 0;
        font-size: 44px;
        font-weight: 900;
        color: #000;
        text-transform: uppercase;
        line-height: 1.1; /* Fixed overlapping */
        letter-spacing: -2px;
      }

      .name-card p {
        margin: 20px 0 0;
        font-size: 24px;
        color: #1e293b;
        font-weight: 600;
        letter-spacing: -0.5px;
      }

      .name-card p span {
        color: var(--coral);
        font-weight: 800;
      }

      /* SIDEBAR SECTION */
      .sidebar-col {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .sidebar-box {
        background: var(--card-white);
        border-radius: var(--radius-md);
        padding: 24px;
        border: 1px solid rgba(0, 0, 0, 0.03);
      }

      .box-heading {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        font-weight: 800;
        color: #1e3a8a;
        font-size: 14px;
        text-transform: lowercase;
        letter-spacing: -0.2px;
      }

      .box-heading svg {
        width: 18px;
        height: 18px;
        color: var(--accent);
        stroke-width: 2.5;
      }

      .contact-entry {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
        font-size: 12px;
        font-weight: 500;
        color: var(--text-light);
      }

      .icon-square {
        width: 30px;
        height: 30px;
        background: #f1f5f9;
        color: var(--coral);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 10px;
      }

      /* MAIN CONTENT SECTION */
      .main-body-card {
        background: var(--card-white);
        border-radius: var(--radius-lg);
        padding: 40px;
        border: 1px solid rgba(0, 0, 0, 0.03);
        display: flex;
        flex-direction: column;
        gap: 35px;
      }

      .content-group h2 {
        font-size: 16px;
        font-weight: 800;
        text-transform: uppercase;
        color: #000;
        margin: 0 0 15px;
        padding-bottom: 10px;
        border-bottom: 2px solid #f1f5f9;
        letter-spacing: 1px;
      }

      .profile-bio {
        font-size: 14px;
        line-height: 1.6;
        color: #334155;
        text-align: justify;
      }

      /* EXPERIENCE ITEMS */
      .exp-row {
        margin-bottom: 25px;
        position: relative;
      }

      .exp-row-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 5px;
      }

      .job-pos {
        font-size: 16px;
        font-weight: 800;
        color: #000;
      }

      .job-period-tag {
        font-size: 11px;
        font-weight: 700;
        color: #64748b;
        background: #f8fafc;
        padding: 4px 12px;
        border-radius: 6px;
        border: 1px solid #e2e8f0;
      }

      .job-comp-name {
        font-size: 14px;
        font-weight: 700;
        color: var(--coral);
        margin-bottom: 10px;
        display: block;
      }

      .job-details {
        font-size: 12.5px;
        line-height: 1.6;
        color: #475569;
      }

      /* TAG PILLS */
      .tag-pill-container {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }

      .tag-pill {
        font-size: 9px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        padding: 3px 10px;
        border-radius: 6px;
        color: #475569;
        font-weight: 600;
      }

      .cat-title {
        font-size: 10px;
        font-weight: 800;
        color: #3b82f6;
        text-transform: uppercase;
        margin: 15px 0 8px;
        letter-spacing: 0.5px;
      }
      .cat-title:first-child {
        margin-top: 0;
      }

      /* ACTION BTN */
      .floating-pdf-btn {
        position: fixed;
        bottom: 40px;
        right: 40px;
        background: #0f172a;
        color: white;
        padding: 16px 32px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        text-decoration: none;
        z-index: 1000;
      }
      /* LOGO CLOUD */
      .logo-cloud {
        grid-column: 1 / span 2;
        background: var(--card-white);
        border-radius: var(--radius-lg);
        padding: 20px 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 15px;
        border: 1px solid rgba(0, 0, 0, 0.03);
      }
      .logo-cloud-title {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-light);
        letter-spacing: 1.5px;
      }
      .logo-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
        gap: 30px;
        width: 100%;
      }
      .logo-item {
        height: 35px;
        filter: grayscale(1);
        opacity: 0.7;
        transition: all 0.3s ease;
      }
      .logo-item:hover {
        filter: grayscale(0);
        opacity: 1;
        transform: scale(1.05);
      }
      .logo-item img {
        height: 100%;
        width: auto;
        object-fit: contain;
      }
    </style>
  </head>
  <body>
    <a href="javascript:window.print()" class="floating-pdf-btn no-print">Exportar a PDF</a>

    <div class="cv-wrapper">
      <div class="photo-card">
        <img src={SITE.avatar} alt={SITE.name} />
      </div>

      <div class="name-card">
        <a href="/AndresBI/" class="detail-tag no-print">Detalle Profesional</a>
        <h1>Michael Andres <br /> Castaño</h1>
        <p>Especialista Senior con más de <span>6 años de experiencia</span></p>
      </div>

      <div class="logo-cloud">
        <span class="logo-cloud-title">Trayectoria en Compañías Líderes</span>
        <div class="logo-grid">
          <div class="logo-item"><img src="/AndresBI/Beiersdorf.svg" alt="Beiersdorf" /></div>
          <div class="logo-item"><img src="/AndresBI/terpel.svg" alt="Terpel" /></div>
          <div class="logo-item"><img src="/AndresBI/Adecco.svg" alt="Adecco" /></div>
          <div class="logo-item"><img src="/AndresBI/BAT.svg" alt="British American Tobacco" /></div>
        </div>
      </div>

      <div class="sidebar-col">
        <div class="sidebar-box">
          <div class="box-heading">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.28-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path></svg
            >
            contacto
          </div>
          <div class="contact-entry"><div class="icon-square">ID</div> 1.022.327.760</div>
          <div class="contact-entry">
            <div class="icon-square">📱</div>
            <a href="https://wa.me/573503505586" style="text-decoration: none; color: inherit;"
              >{SITE.phone}</a>
          </div>
          <div class="contact-entry">
            <div class="icon-square">@</div>
            <a href={`mailto:${SITE.email}`} style="text-decoration: none; color: inherit;"
              >{SITE.email}</a>
          </div>
          <div class="contact-entry"><div class="icon-square">📍</div> {SITE.address}</div>
        </div>

        <div class="sidebar-box">
          <div class="box-heading">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c3 3 9 3 12 0v-5"
              ></path></svg
            >
            educación
          </div>
          {
            education.slice(0, 3).map((edu) => (
              <div style="margin-bottom: 12px;">
                <div style="font-size: 12px; font-weight: 800; line-height: 1.2;">{edu.degree}</div>
                <div style="font-size: 11px; color: var(--coral); font-weight: 700;">
                  {edu.institution}
                </div>
                <div style="font-size: 10px; color: var(--text-light);">{edu.period}</div>
              </div>
            ))
          }
        </div>

        <div class="sidebar-box" style="flex-grow: 1;">
          <div class="box-heading">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="m16 8-1.25 1.25M12 11V6M8 8l1.25 1.25M11 13H6M16 11l-1.25-1.25M18 13h-5"
              ></path></svg
            >
            arsenal tecnológico
          </div>
          {
            Object.entries(skills).map(([_, cat]) => (
              <div style="margin-bottom: 15px; border-bottom: 1px solid #f1f5f9; padding-bottom: 10px;">
                <div class="cat-title">{cat.title}</div>
                <div
                  class="tag-pill-container"
                  style="display: grid; grid-template-columns: 1fr 1fr; gap: 4px;"
                >
                  {cat.tools.map((t) => (
                    <span class="tag-pill" style="text-align: center; border-radius: 4px;">
                      {t.name}
                    </span>
                  ))}
                </div>
              </div>
            ))
          }
          <div
            style="margin-top: 20px; font-size: 9px; color: var(--text-light); text-align: center; font-style: italic;"
          >
            Data Architect & AI Strategist.
          </div>
        </div>
      </div>

      <div class="main-body-card">
        <div class="content-group">
          <h2>Resumen Estratégico</h2>
          <div class="profile-bio">
            Estratega y Arquitecto Senior con más de **6 años de experiencia** liderando soluciones de alto valor en Business Intelligence e
            Inteligencia Artificial. Especializado en transformar datos complejos en ventajas
            competitivas mediante un dominio profundo de DAX, SQL, Python, **ChromaDB, n8n** y **Workflows Agénticos** (Antigravity).
            combinados con un enfoque UX/UI premium, entrego herramientas analíticas avanzadas que
            impulsan la toma de decisiones ejecutivas.
          </div>
        </div>

        <div class="content-group">
          <h2>Cronología Profesional</h2>
          {
            experience.slice(0, 6).map((job) => (
              <div class="exp-row">
                <div class="exp-row-header">
                  <div class="job-pos">{job.position}</div>
                  <div class="job-period-tag">{job.period}</div>
                </div>
                <span class="job-comp-name">{job.company}</span>
                <div class="job-details">{job.description}</div>
              </div>
            ))
          }
        </div>

        <div class="content-group">
          <h2>Implementaciones & Consultoría</h2>
          {
            consultancy.map((pro) => (
              <div class="exp-row">
                <div class="exp-row-header">
                  <div class="job-pos">{pro.position}</div>
                  <div class="job-period-tag">{pro.period}</div>
                </div>
                <span class="job-comp-name">{pro.company}</span>
                <div class="job-details">{pro.description}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </body>
</html>
