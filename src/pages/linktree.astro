---
import BaseHead from '../components/BaseHead.astro';
import { SITE } from '../data/site';
import { social } from '../data/social';
import '../styles/global.css';

const title = `Contact | ${SITE.author}`;
const description = "Tarjeta de contacto digital y enlaces rápidos.";

const links = [
  { name: 'WhatsApp Directo', url: 'https://wa.me/tu-numero', icon: '📱', color: 'from-green-500/20 to-green-600/20' },
  { name: 'Descargar CV (PDF)', url: '/cv', icon: '📄', color: 'from-blue-500/20 to-blue-600/20' },
  { name: 'Agendar Llamada', url: 'https://calendly.com/tu-usuario', icon: '🗓️', color: 'from-purple-500/20 to-purple-600/20' },
  ...social.map(s => ({ 
    name: s.name, 
    url: s.url, 
    icon: s.icon === 'github' ? '💻' : s.icon === 'linkedin' ? '🔗' : '🌐',
    color: 'from-slate-500/20 to-slate-600/20'
  }))
];
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      body {
        background: radial-gradient(circle at top, #1e1b4b 0%, #080813 100%);
      }
    </style>
  </head>
  <body class="min-h-screen text-slate-200 p-6 flex flex-col items-center">
    <!-- Ambient Orbs -->
    <div class="fixed top-[-10%] left-[-10%] w-[60%] h-[40%] bg-blue-600/10 rounded-full blur-[100px] pointer-events-none z-0"></div>

    <div class="relative z-10 w-full max-w-sm mt-12">
      <!-- Profile Header -->
      <div class="text-center mb-10">
        <div class="w-24 h-24 bg-gradient-to-br from-blue-600 to-cyan-400 rounded-full mx-auto flex items-center justify-center text-white text-3xl font-black shadow-[0_0_30px_rgba(59,130,246,0.3)] mb-4">
          ABI
        </div>
        <h1 class="text-2xl font-bold text-white mb-1">{SITE.author}</h1>
        <p class="text-xs text-blue-400 font-mono uppercase tracking-widest">{SITE.tagline}</p>
      </div>

      <!-- Links Grid -->
      <div class="space-y-4">
        {links.map(link => (
          <a 
            href={link.url}
            target={link.url.startsWith('http') ? "_blank" : "_self"}
            rel="noopener noreferrer"
            class={`flex items-center gap-4 p-4 rounded-xl border border-white/10 bg-gradient-to-r ${link.color} backdrop-blur-md hover:scale-[1.02] transition-all active:scale-95 group`}
          >
            <span class="text-2xl">{link.icon}</span>
            <span class="font-bold text-sm flex-1">{link.name}</span>
            <span class="text-blue-500 opacity-0 group-hover:opacity-100 transition-opacity">→</span>
          </a>
        ))}
      </div>

      <!-- Footer Action -->
      <div class="mt-12 text-center">
        <a href="/" class="text-xs font-mono text-slate-500 hover:text-blue-400 transition-colors uppercase tracking-widest">
          &lt; Volver al Portafolio_Full /&gt;
        </a>
      </div>
    </div>

    <!-- Live Status Footer -->
    <div class="fixed bottom-8 flex gap-4 text-[8px] font-mono text-slate-600 uppercase tracking-[0.3em]">
      <span>Session: Active</span>
      <span class="text-green-500 animate-pulse">● Online</span>
    </div>
  </body>
</html>
