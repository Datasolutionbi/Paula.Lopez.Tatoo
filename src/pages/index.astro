---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import AboutMe from '../components/sections/AboutMe.astro';
import Projects from '../components/sections/Projects.astro';
import Contact from '../components/sections/Contact.astro';
import BookingCTA from '../components/sections/BookingCTA.astro';
import InkStories from '../components/sections/InkStories.astro';
import BoutiqueFAQ from '../components/sections/BoutiqueFAQ.astro';
import Newsletter from '../components/sections/Newsletter.astro';
import Testimonials from '../components/social/Testimonials.astro';
import TattooSeparator from '../components/ui/TattooSeparator.astro';
---

<BaseLayout>
  <main>
    <!-- 1. Hero Section -->
    <Hero />

    <!-- 2. Gallery Section -->
    <div class="relative overflow-hidden">
      <div class="absolute -left-20 top-20 w-80 h-80 bg-studio-purple/5 ink-stain -z-10 opacity-30"></div>
      <Projects />
    </div>

    <TattooSeparator variant="minimal" className="my-12" />

    <!-- 3. About Me Section -->
    <AboutMe />

    <TattooSeparator variant="minimal" className="my-12" />

    <!-- 4. FAQ Section -->
    <section id="faq" class="py-24 bg-[var(--bg-page)] transition-colors duration-700">
      <div class="px-6 md:px-12 max-w-[1400px] mx-auto">
        <h2 class="font-serif-editorial text-5xl md:text-6xl text-[#222] text-center mb-16">Questions</h2>
        <BoutiqueFAQ />
      </div>
    </section>

    <!-- 5. Booking / Contact Section -->
    <section id="booking" class="py-24 bg-[var(--bg-page)] relative overflow-hidden transition-colors duration-700">
      <div class="absolute -right-20 top-40 w-96 h-96 bg-studio-purple/5 ink-stain -z-10 opacity-20 rotate-45"></div>
      <div class="px-6 md:px-12 max-w-[1400px] mx-auto">
        <Contact />
      </div>
    </section>

  </main>
</BaseLayout>
