---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<BaseLayout title="PAULA LOPEZ | THE SYNTHETIC CATHEDRAL">
    <!-- Hero: The Altar -->
    <section class="relative h-screen flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0 bg-[#00010d]">
            <!-- Hero atmospheric image - Artisan -->
            <img 
                src={`${base}/paula-artisan.png`} 
                alt="Paula Lopez - Artisan" 
                class="w-full h-full object-cover opacity-40 blur-[2px]"
                loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-b from-[#00010d] via-transparent to-[#00010d] z-10 opacity-70 md:opacity-100"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-[#00010d] via-transparent to-[#00010d] z-10 opacity-70 md:opacity-100"></div>
        </div>
        
        <div class="relative z-10 text-center max-w-5xl px-6 mt-16">
            <div class="mb-6 flex justify-center">
                <span class="text-white text-6xl md:text-[10rem] opacity-90 block font-normal relative" style="font-family: 'Great Vibes', cursive; text-shadow: 0 0 20px rgba(255, 171, 241, 0.4), 0 0 40px rgba(255, 171, 241, 0.2);">
                    Paula Lopez
                </span>
            </div>
            <h1 class="font-headline text-[10px] md:text-sm tracking-[0.8em] uppercase text-[#ffabf1] mb-12 opacity-90" data-i18n="hero.label">
                Anime, Realismo y Tinta de Autor
            </h1>
            <p class="font-body italic text-lg md:text-2xl text-on-surface-variant max-w-3xl mx-auto leading-relaxed" data-i18n="hero.quote">
                "Una convergencia entre la obsesión técnica por el color vibrante de la estética geek y el absoluto silencio del ritual del tatuaje."
            </p>
            <div class="mt-20">
                <a href="#liturgia" class="inline-block hover:mt-2 hover:mb-[-8px] transition-all duration-300">
                     <span class="material-symbols-outlined text-[#ffabf1] text-4xl animate-bounce">expand_more</span>
                </a>
            </div>
        </div>
    </section>

    <!-- Visual Liturgy Section -->
    <section id="liturgia" class="py-24 md:py-32 px-5 md:px-24 bg-[#090d1d] relative">
         <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-[#8c2786]/5 blur-[120px] rounded-full pointer-events-none -z-10"></div>
        <div class="flex flex-col md:flex-row justify-between items-end mb-24 gap-8">
            <div>
                <h2 class="font-headline text-3xl md:text-5xl tracking-[0.3em] uppercase text-white mb-4" data-i18n="home.pillars.title">Los Tres Pilares</h2>
                <p class="font-body italic text-xl text-[#9bcaff] opacity-70" data-i18n="home.pillars.sub">Saturación suprema y contrastes absolutos en piel.</p>
            </div>
            <div class="text-right">
                <a class="font-headline text-[10px] tracking-widest uppercase text-[#ffabf1] border-b border-[#ffabf1]/20 pb-2 hover:border-[#ffabf1] transition-all" href={`${base}/portafolio`} data-i18n="home.pillars.link">Ver Obra Completa</a>
            </div>
        </div>
        
        <!-- Grid: 3 panels per row -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-16">
            <!-- Panel 1: Realismo -->
            <a href={`${base}/portafolio?filter=realismo`} class="block group relative aspect-[3/4] bg-[#00010d] overflow-hidden hover:-translate-y-2 transition-transform duration-700 altar-border">
                <div class="absolute -top-px -left-px w-6 h-6 border-t border-l border-primary opacity-0 group-hover:opacity-100 z-10 transition-opacity duration-500"></div>
                <img class="w-full h-full object-cover grayscale brightness-75 group-hover:grayscale-0 group-hover:brightness-100 group-hover:scale-105 transition-all duration-1000" alt="Tatuaje de realismo animal" src={`${base}/portafolio/image copy 10.png`} onerror={`this.src='https://lh3.googleusercontent.com/aida-public/AB6AXuDtcwWpKnQtdX5VushUbaioKvbW10ySoNWGoFrccMN5r8jQqIy5mQs2M1tqP28f-ncck3irElrVS_11QIzdgdDjKL4RiWk-5Z9A5nCBgHa0PhYuW8n9grqYhQGZSqCObuh7-Br3MClqIdyndAQRuSOedYZ1EffJvnDOVdtgA8OLJ7blE3uEuRYU18kp5kqTxiGRZs-9yHbFD7pvPol-b59K2Kb06AdGrNgcqVjeW-2C-hBbcxBFOh_JfEV5ldaj989uMJ88CJiqlvw'`} />
                <div class="absolute inset-0 bg-gradient-to-t from-[#00010d] via-[#00010d]/40 to-transparent"></div>
                <div class="absolute bottom-0 left-0 p-8 z-30 transform group-hover:-translate-y-2 transition-transform duration-500">
                    <h3 class="font-headline text-sm tracking-[0.3em] uppercase text-[#ffabf1] mb-2" data-i18n="home.p1.title">Biorealismo</h3>
                    <p class="font-body italic text-sm text-white/70" data-i18n="home.p1.sub">Texturas precisas y retratos hiper-detallados.</p>
                </div>
            </a>
            
            <!-- Panel 2: Anime -->
            <a href={`${base}/portafolio?filter=anime`} class="block group relative aspect-[3/4] bg-[#00010d] overflow-hidden hover:-translate-y-2 transition-transform duration-700 altar-border">
                 <div class="absolute -bottom-px -right-px w-6 h-6 border-b border-r border-[#ffabf1] opacity-0 group-hover:opacity-100 z-10 transition-opacity duration-500"></div>
                <img class="w-full h-full object-cover grayscale brightness-75 group-hover:grayscale-0 group-hover:brightness-100 group-hover:scale-105 transition-all duration-1000" alt="Tatuaje anime manga dragon ball full color" src={`${base}/portafolio/image copy 35.png`} onerror={`this.src='https://lh3.googleusercontent.com/aida-public/AB6AXuCqsmm49MlyCi694nRq025yUGMQs1-IHRoE2fCeTmkLv4jLOvMR-wc29Wc-cKYVzeXMtM42KnaHsT-MSjz20PCts6qRLODOA8UUS6Yub2LPZo3-l9zs81pLQponko3mUvFwERnqdCkxUn4oQFJOtKNV7-GeGGMXfWTR29nc-WIztiqrhBmEjDWh0zr3KNnebfxp_E1PUUrNnwSq45nlVj6DDL-BYR10j_iugqs0Q2Qvns93blmq7R5ecOto8wT_L17bxg6VTbRbxMI'`} />
                <div class="absolute inset-0 bg-gradient-to-t from-[#00010d] via-[#00010d]/40 to-transparent"></div>
                <div class="absolute bottom-0 left-0 p-8 z-30 transform group-hover:-translate-y-2 transition-transform duration-500">
                    <h3 class="font-headline text-sm tracking-[0.3em] uppercase text-[#ffabf1] mb-2" data-i18n="home.p2.title">Anime & Full Color</h3>
                    <p class="font-body italic text-sm text-white/70" data-i18n="home.p2.sub">Saturación cromática extrema y fidelidad a la línea.</p>
                </div>
            </a>
            
            <!-- Panel 3: Blackwork/Dark -->
            <a href={`${base}/portafolio?filter=blackwork`} class="block group relative aspect-[3/4] bg-[#00010d] overflow-hidden hover:-translate-y-2 transition-transform duration-700 altar-border">
                <div class="absolute -top-px -right-px w-6 h-6 border-t border-r border-primary opacity-0 group-hover:opacity-100 z-10 transition-opacity duration-500"></div>
                <img class="w-full h-full object-cover grayscale brightness-75 group-hover:grayscale-0 group-hover:brightness-100 group-hover:scale-105 transition-all duration-1000" alt="Tatuaje blackwork" src={`${base}/portafolio/toro.gif`} onerror={`this.src='https://lh3.googleusercontent.com/aida-public/AB6AXuAGUQkrTQtVpV3r4JrW8Fp4_Yu5M4ATdoMjkF1NwZ6Rk-gcBIU_K6P-QLbm4LkKXNWVR85cULZ0Vi-WnJSFM_18gz5QeXTdJbK6PjvXgYV6-mQ_UvQxqqJFMhqeRirfCDmPN_HZ59IDUI4DOIJVU_Wi7MDkTo7WMr4qbVizRk52xHDqjWZUfdpS40HwVpYYkLd2iA6FekuJtGtfmjkWM1XHe3csmvw1tCBXoHdPtSrdN_ey6PMj4Y2XXkbOBB-8tOqbMkJHQRq1TxY'`} />
                <div class="absolute inset-0 bg-gradient-to-t from-[#00010d] via-[#00010d]/40 to-transparent"></div>
                <div class="absolute bottom-0 left-0 p-8 z-30 transform group-hover:-translate-y-2 transition-transform duration-500">
                    <h3 class="font-headline text-sm tracking-[0.3em] uppercase text-[#ffabf1] mb-2" data-i18n="home.p3.title">Blackwork de Autor</h3>
                    <p class="font-body italic text-sm text-white/70" data-i18n="home.p3.sub">Altos contrastes, línea sólida y sombras profundas.</p>
                </div>
            </a>
        </div>
    </section>

    <!-- Poetic Intervention -->
    <section class="py-32 px-8 text-center bg-[#00010d] border-y border-outline-variant/10">
        <div class="max-w-4xl mx-auto">
            <span class="material-symbols-outlined text-[#ffabf1] text-5xl mb-12 block opacity-80" style="font-variation-settings: 'FILL' 1;">flare</span>
            <blockquote class="font-body italic text-2xl md:text-4xl text-white leading-relaxed" data-i18n="home.quote.text">
                "La piel humana no es un papel en blanco, es una catedral que exige devoción. Traemos el neón a la oscuridad."
            </blockquote>
            <cite class="mt-12 block font-headline text-[10px] tracking-[0.4em] uppercase text-[#9bcaff]" data-i18n="home.quote.author">Paula Angels</cite>
        </div>
    </section>

    <!-- Process Bento -->
    <section class="py-32 px-8 md:px-24 bg-[#090d1d] border-b border-outline-variant/10">
        <h2 class="font-headline text-xs tracking-[0.5em] uppercase text-white/50 mb-16 text-center" data-i18n="home.process.title">Protocolo de Estudio</h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 max-w-[1400px] mx-auto">
            
            <div class="md:col-span-2 bg-[#00010d] h-[400px] flex flex-col justify-end p-12 relative overflow-hidden altar-border group">
                <img class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:opacity-50 transition-opacity duration-700 mix-blend-luminosity" alt="Proceso de tatuaje y atmósfera" src={`${base}/portafolio/proceso.gif`} onerror={`this.src='https://lh3.googleusercontent.com/aida-public/AB6AXuBJHQnqNs9B2ejK-1utDn3zv2EFrtA8EF6CKfU-spIcWea-n--oABwZOx4vugv-pr1WHeYlH7Zk_cXKKsF-hnFl-4anBl1w7Loq-T2dY1971UgowuOIiEQK11au2pj7vo8AsYtAoQfl39t_L_Qgn7ybkVly4FL3VT_lLfUOrotuIplG9cRjVDthdvfOhOMzw5cvoqCtY7t2QIgo3b0YjFJeOJgG9os12WMZvrZlMUP4DCwvYHbRLy8XC9NJ-B2ayvPUVcu7c1tvcoM'`} />
                <div class="absolute inset-0 bg-gradient-to-t from-[#00010d] to-transparent"></div>
                <h4 class="relative z-10 font-headline text-lg tracking-[0.2em] uppercase text-white">Atmósfera & Diseño</h4>
                <p class="relative z-10 font-body italic text-white/60 mt-2 max-w-sm">Música selecta, estética visual de autor y privacidad. El nacimiento de la pieza única.</p>
            </div>
            
            <div class="bg-[#00010d] h-[400px] flex flex-col justify-end p-10 altar-border hover:bg-white/5 transition-colors duration-500">
                <h4 class="font-headline text-sm tracking-[0.2em] uppercase text-[#ffabf1]" data-i18n="home.step2.title">Curación</h4>
                <p class="font-body italic text-white/60 mt-3" data-i18n="home.step2.sub">Diseños personalizados enfocados en longevidad visual en la piel y fluidez orgánica.</p>
            </div>
            
            <div class="bg-[#00010d] h-[400px] flex flex-col justify-end p-10 altar-border hover:bg-white/5 transition-colors duration-500 relative overflow-hidden group">
               <img class="absolute inset-0 w-full h-full object-cover opacity-10 group-hover:opacity-20 transition-opacity duration-700" alt="Máquina de tatuar de precisión" src={`${base}/portafolio/camara.gif`} />
               <div class="absolute inset-0 bg-gradient-to-t from-[#00010d] via-[#00010d]/90 to-transparent"></div>
               <h4 class="relative z-10 font-headline text-sm tracking-[0.2em] uppercase text-[#9bcaff]" data-i18n="home.step3.title">La Sesión</h4>
               <p class="relative z-10 font-body italic text-white/60 mt-3" data-i18n="home.step3.sub">Técnica impecable y esterilización clínica. Equipamiento de élite para traumatismo minimizado.</p>
            </div>

        </div>
    </section>
</BaseLayout>
