---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;

const currilum = [
    { module: "Módulo I", title: "Arquitectura de la Piel", desc: "Tensión, estiramiento y entendimiento de las capas dérmicas para inyección profunda." },
    { module: "Módulo II", title: "Dinámica de Sombras", desc: "El origen de la fuente de luz. Alto contraste y técnicas de saturación para Blackwork impecable." },
    { module: "Módulo III", title: "Geometría Sagrada", desc: "Trazado milimétrico sin error. Técnicas para evitar temblor y asegurar simetría absoluta." },
    { module: "Módulo IV", title: "El Ritual del Cliente", desc: "Psicología, manejo del dolor, y la conversión de nuestro estudio en una Catedral sintética." }
];
---

<BaseLayout title="PAULA LOPEZ | SEMINARIOS">
    <main class="w-full min-h-screen pb-20 px-8 lg:px-24 mx-auto flex flex-col z-10 max-w-[1400px]">
        <!-- Spacer invisible para asegurar área bajo el navbar fijo -->
        <div class="w-full h-32 md:h-48 shrink-0"></div>
        
        <!-- Header -->
        <div class="mb-20 text-center flex flex-col items-center">
            <h1 class="font-headline text-[10px] tracking-[0.5em] text-secondary uppercase mb-6">Transmisión de Conocimiento</h1>
            <h2 class="font-headline text-5xl lg:text-7xl font-extralight tracking-tight uppercase text-on-surface">
                Master<span class="text-primary italic font-body">classes</span>
            </h2>
            <div class="h-px w-24 bg-outline-variant/30 mt-12"></div>
            <p class="font-body italic text-on-surface-variant max-w-2xl mt-12 leading-relaxed opacity-80">
                El conocimiento no debe estancarse; debe tallarse en las siguientes generaciones. Aquí se ofrecen los seminarios profesionales para artistas avanzados.
            </p>
        </div>

        <!-- Featured Upcoming Seminar -->
        <div class="relative group w-full bg-[#090d1d] border border-primary/20 overflow-hidden mb-24 flex flex-col lg:flex-row">
            <!-- Decorative Corners -->
            <div class="absolute top-0 left-0 w-8 h-8 border-t border-l border-primary/60 opacity-0 group-hover:opacity-100 transition-all duration-500 z-30"></div>
            
            <!-- Left Side Element: Image -->
            <div class="w-full lg:w-1/2 aspect-video lg:aspect-auto relative overflow-hidden">
                <img 
                    src={`${base}/tatuajes/3.webp`} 
                    onerror={`this.src='https://lh3.googleusercontent.com/aida-public/AB6AXuAGSml2HFzCewoCIaDjxidM90iY7LXBq6uDFzvxPdiUG1PzNIv13f5v5KEWmWPLIlGxcAA8n53NaCshzhu4QhGfQh308MaCpUfr-zoxMb1nJ5FfrHzIQB7x9BL_tNHnj7sLFnsc398TZGukeWDqJoZOcZsJxjb4HxawaT_WmQTDWR-sy_ghaPKIkyo0Y7gIBIP830IlGpvAru3436cTPbQy8QzpUzWgh8aCyMVoGwW7g2W1vMPs4rGYrAgHS_paao-XGczmY8OsThE'`}
                    alt="Seminario Masterclass"
                    class="absolute inset-0 w-full h-full object-cover filter   brightness-50 group-hover:scale-105 transition-transform duration-[2000ms]"
                />
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-[#090d1d]/80 to-[#090d1d] hidden lg:block"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-[#090d1d] to-transparent lg:hidden"></div>
            </div>

            <!-- Right Side Element: Info -->
            <div class="w-full lg:w-1/2 p-8 lg:p-16 flex flex-col justify-center relative z-10">
                <div class="flex items-center gap-4 mb-6">
                    <span class="inline-block w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                    <span class="font-headline text-[9px] tracking-[0.4em] text-primary uppercase border border-primary/30 px-3 py-1">Inscripciones Abiertas</span>
                </div>
                
                <h3 class="font-headline text-3xl md:text-5xl tracking-widest text-[#ffabf1] uppercase mb-4">Blackwork in The Shadows</h3>
                <p class="font-headline text-xs tracking-[0.3em] text-on-surface-variant uppercase mb-8">Noviembre 2026 · Madrid - España</p>
                
                <p class="font-body italic text-on-surface-variant leading-relaxed mb-12 opacity-80">
                    Un programa intensivo presencial de 3 días diseñado para tatuadores que desean romper los límites del contraste. Aprende a diseñar piezas monumentales, domina la inyección de tinta pura sin grises premezclados, y construye composiciones que fluyan con la anatomía humana.
                </p>

                <a href={`${base}/contacto`} class="inline-block relative overflow-hidden group/btn px-10 py-5 bg-primary/10 border border-primary hover:bg-primary transition-colors duration-500 w-fit">
                    <span class="relative z-10 font-headline tracking-[0.3em] text-[10px] uppercase text-white">Aplicar por un Cupo</span>
                </a>
            </div>
        </div>

        <!-- Curriculum / Modules Grid -->
        <h3 class="font-headline text-center text-sm md:text-base tracking-[0.4em] uppercase text-secondary mb-16 border-b border-outline-variant/10 pb-8">
            Estructura del Conocimiento
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-24">
            {currilum.map((item) => (
                <div class="p-8 border border-outline-variant/10 bg-[#00010d] group hover:border-[#ffabf1]/40 transition-colors duration-500 relative overflow-hidden">
                    <!-- Glow en hover -->
                    <div class="absolute inset-0 bg-primary/5 opacity-0 group-hover:opacity-100 transition-opacity duration-700 blur-[30px] z-0"></div>
                    
                    <div class="relative z-10">
                        <span class="font-headline text-[10px] tracking-widest text-[#7a462a] uppercase block mb-4 group-hover:text-primary transition-colors">{item.module}</span>
                        <h4 class="font-headline text-xl tracking-wider text-white uppercase mb-4">{item.title}</h4>
                        <p class="font-body italic text-on-surface-variant text-sm leading-relaxed opacity-70 group-hover:opacity-100 transition-opacity">
                            {item.desc}
                        </p>
                    </div>
                </div>
            ))}
        </div>

    </main>
</BaseLayout>
