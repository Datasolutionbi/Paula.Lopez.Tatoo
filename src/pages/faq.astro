---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;

const faqs = [
    {
        question: "¿Cuál es el proceso para agendar un tatuaje?",
        answer: "El proceso consta de un ritual en el que debes llenar el formulario de 'Consulta'. Evaluaremos la idea y si resuena con nuestra línea gráfica (Blackwork, Surrealismo Oscuro), nos pondremos en contacto para un estudio y presupuesto. Tomamos un número muy exclusivo de casos por mes."
    },
    {
        question: "¿Realizas o copias diseños de otros artistas?",
        answer: "No. The Synthetic Cathedral es un altar de diseño original. Cada pieza es elaborada exclusivamente para la anatomía e historia de quien la portará. Las referencias que envíes servirán de inspiración de ánimo o composición, pero jamás para reproducirse de forma literal."
    },
    {
        question: "¿Cuál es la tarifa mínima o el valor de una sesión?",
        answer: "Debido a la naturaleza inmersiva de los tatuajes y el hiper-detalle, tarificamos mayormente por proyecto completo o 'día de sesión' completo y no por horas sueltas. La información financiera exacta siempre se entregará una vez revisado y aprobado el concepto de tu obra."
    },
    {
        question: "¿Haces arreglos (cover-ups) de tatuajes antiguos?",
        answer: "Los 'cover-ups' son aceptados únicamente tras una revisión fotográfica exhaustiva de la zona. Se necesita muchísima libertad creativa con tinta negra saturada y un formato mediano/grande para cubrir trabajos problemáticos efectivamente."
    },
    {
        question: "¿Cómo debo prepararme para la Sesión/Ritual?",
        answer: "Evita el alcohol y medicamentos anticoagulantes 48 horas antes. Exfolia la piel suavemente tres días previos e hidrátala con abundancia. El día de tu sesión, descansa lo suficiente, alimentate bien y trae elementos de comfort (audífonos o libros), en el estudio mantenemos un ambiente de absoluto respeto y silencio."
    }
];
---

<BaseLayout title="PAULA LOPEZ | FAQ">
    <main class="w-full min-h-screen pb-20 px-8 lg:px-24 mx-auto flex flex-col z-10 max-w-[1400px]">
        <!-- Spacer invisible para asegurar área bajo el navbar fijo -->
        <div class="w-full h-32 md:h-48 shrink-0"></div>
        
        <!-- Header -->
        <div class="mb-16 md:mb-24 text-center md:text-left flex flex-col items-center md:items-start">
            <h1 class="font-headline text-[10px] tracking-[0.5em] text-secondary uppercase mb-6">Oráculo y Guía</h1>
            <h2 class="font-headline text-4xl md:text-5xl lg:text-7xl font-extralight tracking-tight uppercase text-on-surface">
                FAQ / <span class="text-primary italic font-body">Consultas</span>
            </h2>
            <div class="h-px w-24 bg-outline-variant/30 mt-12 md:mr-auto"></div>
        </div>

        <!-- FAQ List using Native HTML details/summary for zero-js accordion -->
        <div class="w-full max-w-4xl mx-auto md:mx-0 flex flex-col gap-6">
            {faqs.map((faq) => (
                <details class="group bg-[#090d1d] border border-outline-variant/10 open:border-primary/40 transition-colors duration-500 cursor-pointer">
                    <summary class="flex justify-between items-center px-8 py-6 list-none font-headline tracking-[0.1em] md:tracking-[0.2em] uppercase text-sm text-[#ffabf1] hover:text-white transition-colors">
                        {faq.question}
                        <span class="material-symbols-outlined text-outline-variant group-open:rotate-45 group-open:text-primary transition-transform duration-300">add</span>
                    </summary>
                    <div class="px-8 pb-8 pt-2">
                        <div class="h-px w-12 bg-primary/20 mb-6"></div>
                        <p class="font-body italic text-on-surface-variant text-base md:text-lg leading-relaxed opacity-80">
                            "{faq.answer}"
                        </p>
                    </div>
                </details>
            ))}
        </div>

        <!-- Final Notice -->
        <div class="mt-24 md:mt-32 max-w-4xl border-l border-primary/40 pl-8 md:pl-12 py-4">
            <h3 class="font-headline text-[10px] tracking-[0.3em] uppercase text-secondary mb-4">¿No encontraste tu respuesta?</h3>
            <p class="font-body text-sm text-on-surface-variant leading-loose opacity-70">
                Si tu duda requiere interpretación profunda o es respecto a un lienzo (cuerpo) con características médicas únicas, por favor refiérase al portal de contacto. 
            </p>
            <a href={`${base}/contacto`} class="inline-block mt-6 text-[#ffabf1] hover:text-white font-headline text-xs tracking-widest uppercase transition-colors">
                Ir al formulario de Contacto →
            </a>
        </div>
    </main>
</BaseLayout>

<style>
    /* Ocultar el triangulito por defecto de <details> en Safari/Chrome/Firefox */
    details > summary::-webkit-details-marker {
        display: none;
    }
</style>
