---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../../utils/readingTime';

// Get all blog posts
const allPosts = await getCollection('blog');

// Sort by date (newest first) and filter drafts
const publishedPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// Get unique categories
const categories = [...new Set(allPosts.map(post => post.data.category))];

// Get reading times
const postsWithReadingTime = publishedPosts.map(post => ({
  ...post,
  readingTime: getReadingTime(post.body)
}));
---

<BaseLayout title="Blog | Insights sobre BI y Analítica de Datos">
  <div class="container-custom section-padding">
    <!-- Header -->
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-4">Blog</h1>
      <p class="text-xl text-slate-600">
        Insights, tutoriales y mejores prácticas en Business Intelligence, Analítica de Datos e Inteligencia Artificial.
      </p>
    </div>

    <!-- Categories Filter (optional for future) -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      <a href="/blog" class="badge-primary">
        Todos
      </a>
      {categories.map(category => (
        <a href={`/blog/category/${category.toLowerCase()}`} class="badge-secondary hover:bg-slate-200 transition-colors">
          {category}
        </a>
      ))}
    </div>

    <!-- Blog Posts Grid -->
    {postsWithReadingTime.length > 0 ? (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {postsWithReadingTime.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            publishDate={post.data.publishDate}
            category={post.data.category}
            slug={post.slug}
            readingTime={post.readingTime}
          />
        ))}
      </div>
    ) : (
      <div class="text-center text-slate-500 py-12">
        <p class="text-lg">Próximamente publicaré artículos sobre BI, Analytics e IA...</p>
      </div>
    )}
  </div>
</BaseLayout>
