---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import AboutMe from '../../components/sections/AboutMe.astro';
import Projects from '../../components/sections/Projects.astro';
import Contact from '../../components/sections/Contact.astro';
import BookingCTA from '../../components/sections/BookingCTA.astro';
import InkStories from '../../components/sections/InkStories.astro';
import BoutiqueFAQ from '../../components/sections/BoutiqueFAQ.astro';
import Newsletter from '../../components/sections/Newsletter.astro';
import Testimonials from '../../components/social/Testimonials.astro';
import TattooSeparator from '../../components/ui/TattooSeparator.astro';
---

<BaseLayout lang="en">
  <main>
    <!-- Hero Section -->
    <Hero content={{ label: "ARTIST OF THE DAY", title: "THE KIND OF TATTOO YOU WON'T REGRET" }} />

    <!-- Gallery / Work -->
    <section id="work" class="py-12 bg-white relative">
        <div class="container-custom mb-10 text-center">
            <h2 class="font-display text-4xl md:text-5xl text-black mb-2 uppercase tracking-tight">Selected Works</h2>
            <div class="w-16 h-0.5 bg-studio-purple mx-auto"></div>
        </div>
        <Projects />
    </section>

    <TattooSeparator variant="needle" />

    <!-- About Me -->
    <AboutMe isEn={true} />

    <TattooSeparator variant="voltage" />

    <!-- Transformations -->
    <section id="stories" class="py-12 bg-white relative">
       <div class="container-custom">
            <InkStories title="TRANSFORMATIONS" label="DRAG TO REVEAL" />
       </div>
    </section>

    <TattooSeparator variant="minimal" />
    
    <!-- Testimonials -->
    <section id="reviews" class="py-12 bg-bg-secondary">
        <div class="container-custom mb-10 text-center">
            <h2 class="font-display text-4xl md:text-5xl text-black mb-2 uppercase tracking-tight">Client Stories</h2>
            <div class="w-16 h-0.5 bg-studio-purple mx-auto"></div>
        </div>
        <Testimonials isEn={true} />
    </section>

    <TattooSeparator variant="needle" />

    <!-- FAQ -->
    <section id="faq" class="py-12 bg-white">
        <div class="container-custom max-w-4xl">
             <h2 class="font-display text-4xl text-center mb-8 uppercase tracking-tight">Common Questions</h2>
             <BoutiqueFAQ isEn={true} />
        </div>
    </section>

    <TattooSeparator variant="voltage" />

    <!-- Booking Block -->
    <div id="booking">
        <!-- Hype & Socials -->
        <BookingCTA isEn={true} />
        
        <TattooSeparator variant="minimal" />

        <!-- Actual Form -->
        <section class="py-12 bg-bg-secondary">
            <div class="container-custom">
                <Contact />
            </div>
        </section>
    </div>

  </main>
  <Newsletter />
</BaseLayout>
