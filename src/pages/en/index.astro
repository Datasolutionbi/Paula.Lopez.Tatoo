---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import About from '../../components/sections/About.astro';
import Projects from '../../components/sections/Projects.astro';
import Skills from '../../components/sections/Skills.astro';
import Experience from '../../components/sections/Experience.astro';
import Education from '../../components/sections/Education.astro';
import Contact from '../../components/sections/Contact.astro';
import NeuralPerceptron from '../../components/NeuralPerceptron.astro';
import { skills } from '../../data/skills';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(project => project.data.featured)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const experience = [
  {
    company: "TechCorp Analytics",
    position: "Senior BI & AI Specialist",
    period: "2022 - Present",
    description: "I lead BI projects and predictive analysis with AI. I develop interactive dashboards and machine learning models for process optimization.",
    achievements: [
      "Reduced reporting time by 85% through automation with Power BI",
      "Implemented sales prediction model with 92% accuracy",
      "Designed ETL pipeline processing 10M+ daily records"
    ],
    tech: ["Power BI", "Python", "Azure ML", "SQL Server", "Airflow"]
  },
  {
    company: "DataViz Solutions",
    position: "Data Analyst",
    period: "2020 - 2022",
    description: "Data analyst focused on visualization and business reporting. Creation of dashboards and exploratory data analysis.",
    achievements: [
      "Created 50+ interactive dashboards in Tableau",
      "Optimized SQL queries reducing execution time by 70%",
      "Trained 30+ users in BI tools"
    ],
    tech: ["Tableau", "SQL", "Excel", "Python", "Power Query"]
  }
];

const education = [
  {
    degree: "Master in Data Science & BI",
    institution: "Tech University",
    period: "2018 - 2019",
    description: "Specialization in advanced analytics and business intelligence."
  }
];

const certifications = [
  { name: "Microsoft Certified: Power BI Data Analyst", issuer: "Microsoft", year: "2023" },
  { name: "Azure Machine Learning Associate", issuer: "Microsoft", year: "2022" }
];
---

<BaseLayout title="Portfolio | AndresBI" description="BI Specialist, Data Visualization and AI" lang="en">
  <div class="reveal-blur">
    <Hero />
  </div>

  <About isEn={true}>
    <NeuralPerceptron size={80} slot="perceptron" />
  </About>

  <div class="section-divider"></div>

  <Projects isEn={true} projects={featuredProjects} />

  <div class="section-divider"></div>

  <Skills isEn={true} skills={skills} />

  <div class="section-divider"></div>

  <Experience isEn={true} experience={experience} />

  <div class="section-divider"></div>

  <Education isEn={true} education={education} certifications={certifications} />

  <div class="section-divider"></div>

  <Contact isEn={true} />
</BaseLayout>
