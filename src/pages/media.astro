---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;

// Placeholder media items - normally these would come from a CMS or local folder
const mediaItems = [
    { src: `${base}/portafolio/proceso_inicial.gif`, type: 'video', title: 'The Process', duration: '0:45' },
    { src: `${base}/portafolio/image copy 8.png`, type: 'image', title: 'Exhibition', duration: '' },
    { src: `${base}/portafolio/camara.gif`, type: 'video', title: 'Session I', duration: '1:20' },
    { src: `${base}/portafolio/image copy 23.png`, type: 'image', title: 'Gallery', duration: '', href: `${base}/portafolio` },
    { src: `${base}/portafolio/image copy 10.png`, type: 'image', title: 'Studio', duration: '' },
    { src: `${base}/portafolio/proceso_secion_2.gif`, type: 'video', title: 'Session II', duration: '0:55' }
];
---

<BaseLayout title="PAULA LOPEZ | MEDIA">
    <main class="w-full min-h-screen pb-20 px-5 md:px-24 mx-auto flex flex-col z-10 max-w-[1800px]">
        <!-- Spacer invisible para asegurar área bajo el navbar fijo -->
        <div class="w-full h-32 md:h-48 shrink-0"></div>
        
        <!-- Media Header -->
        <div class="mb-20 text-center flex flex-col items-center">
            <h1 class="font-headline text-[10px] tracking-[0.5em] text-secondary uppercase mb-6">Digital Relics</h1>
            <h2 class="font-headline text-5xl lg:text-7xl font-extralight tracking-tight uppercase text-on-surface">
                Visual <span class="text-primary italic font-body">Liturgy</span>
            </h2>
            <div class="h-px w-24 bg-outline-variant/30 mt-12"></div>
            <p class="font-body italic text-on-surface-variant max-w-2xl mt-12 leading-relaxed opacity-80">
                Registros atmosféricos del proceso creativo y de la manipulación de las sombras en la Piel. El altar visual desde la concepción hasta la cicatrización.
            </p>
        </div>

        <!-- Layout Grilla Masonry/Bento para contenido multimedia -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:auto-rows-[300px]">
            {mediaItems.map((item, index) => {
                const Element = item.href ? 'a' : 'div';
                return (
                <Element href={item.href} class={`relative block group overflow-hidden bg-[#090d1d] border border-outline-variant/10 cursor-pointer ${index === 0 ? 'md:col-span-2 lg:row-span-2' : ''} ${index === 2 ? 'lg:col-span-2' : ''}`}>
                    <!-- Ambient Glow Effect on Hover -->
                    <div class="absolute inset-0 bg-primary/20 opacity-0 group-hover:opacity-100 transition-opacity duration-700 blur-[50px] z-0"></div>
                    
                    <!-- Decorative Corners -->
                    <div class="absolute top-4 left-4 w-4 h-4 border-t border-l border-primary/40 opacity-0 group-hover:opacity-100 transition-all duration-500 z-30"></div>
                    <div class="absolute bottom-4 right-4 w-4 h-4 border-b border-r border-primary/40 opacity-0 group-hover:opacity-100 transition-all duration-500 z-30"></div>

                    <!-- Img Placeholder Fallback Flow -->
                    <img 
                        src={item.src} 
                        onerror={`this.src='https://lh3.googleusercontent.com/aida-public/AB6AXuAGSml2HFzCewoCIaDjxidM90iY7LXBq6uDFzvxPdiUG1PzNIv13f5v5KEWmWPLIlGxcAA8n53NaCshzhu4QhGfQh308MaCpUfr-zoxMb1nJ5FfrHzIQB7x9BL_tNHnj7sLFnsc398TZGukeWDqJoZOcZsJxjb4HxawaT_WmQTDWR-sy_ghaPKIkyo0Y7gIBIP830IlGpvAru3436cTPbQy8QzpUzWgh8aCyMVoGwW7g2W1vMPs4rGYrAgHS_paao-XGczmY8OsThE'`}
                        alt={item.title}
                        class="absolute inset-0 w-full h-full object-cover filter   brightness-50 group-hover:brightness-90 scale-100 group-hover:scale-105 transition-all duration-[1500ms] z-10"
                    />

                    <!-- Overlay UI Elements -->
                    <div class="absolute inset-x-0 bottom-0 p-8 flex justify-between items-end bg-gradient-to-t from-black via-black/80 to-transparent z-20">
                        <div>
                            <span class="font-headline text-[8px] tracking-[0.4em] text-primary uppercase block mb-2 opacity-80">{item.type}</span>
                            <h3 class="font-headline text-lg tracking-widest text-[#ffabf1] uppercase">{item.title}</h3>
                        </div>
                        {item.type === 'video' && (
                            <div class="flex items-center gap-2">
                                <span class="font-body text-xs text-secondary opacity-60">{item.duration}</span>
                                <span class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform">play_circle</span>
                            </div>
                        )}
                        {item.type === 'image' && (
                            <span class="material-symbols-outlined text-secondary opacity-50 group-hover:opacity-100 transition-opacity">visibility</span>
                        )}
                    </div>
                </Element>
            )})}
        </div>

        <!-- Accion -->
        <div class="mt-24 text-center">
            <a href="https://instagram.com/tattocaro" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-4 px-10 py-5 border border-outline-variant hover:border-primary transition-colors text-on-surface hover:text-[#ffabf1] font-headline tracking-[0.3em] uppercase text-xs group">
                Explorar el Archivo Completo 
                <span class="material-symbols-outlined text-sm group-hover:translate-x-2 transition-transform">arrow_forward</span>
            </a>
        </div>

    </main>
</BaseLayout>
